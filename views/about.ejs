<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="About EcomSphere - Our Story and Mission">
  <title><%= title %></title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('./partials/header') %>

  <section id="page-header" class="about-header">
    <h2>About EcomSphere</h2>
    <p>Our story and mission</p>
  </section>

  <section id="about-head" class="section-p1">
    <img src="/img/about/about.jpg" alt="About EcomSphere" onerror="this.src='/img/placeholder.jpg'">
    <div>
      <h2>Who Are We?</h2>
      <p>EcomSphere is a premium e-commerce platform offering a curated selection of clothing, footwear, glasses, and cosmetics. We believe shopping should be simple, enjoyable, and trustworthy.</p>
      <p>Our mission is to bring the best products to your doorstep with fast shipping, easy returns, and excellent customer support.</p>
      <h4>Our Values</h4>
      <p><i class="fa-solid fa-check" style="color:#088178; margin-right:8px;"></i> Quality first — only premium products</p>
      <p><i class="fa-solid fa-check" style="color:#088178; margin-right:8px;"></i> Customer satisfaction guaranteed</p>
      <p><i class="fa-solid fa-check" style="color:#088178; margin-right:8px;"></i> Secure and transparent transactions</p>
      <p><i class="fa-solid fa-check" style="color:#088178; margin-right:8px;"></i> Fast and free shipping nationwide</p>
    </div>
  </section>

  <section id="newsletter" class="section-p1 section-m1">
    <div class="newstext">
      <h4>Sign Up For Newsletter</h4>
      <p>Get E-mail updates about our latest shop and <span>special offers.</span></p>
    </div>
    <div class="form">
      <input type="text" placeholder="Your E-mail address">
      <button class="normal">Sign Up</button>
    </div>
  </section>

  <%- include('./partials/footer') %>
  <script src="/js/script.js"></script>
</body>
</html>
