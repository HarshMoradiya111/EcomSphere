<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Checkout - EcomSphere">
  <title><%= title %></title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    #checkout-container { max-width: 900px; margin: 50px auto; padding: 25px; background: #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.1); border-radius: 12px; }
    #checkout-container h2 { font-size: 28px; color: #333; margin-bottom: 20px; text-align:center; }
    #checkout-summary { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    #checkout-summary th, #checkout-summary td { border: 1px solid #ddd; padding: 14px; text-align: center; }
    #checkout-summary th { background-color: #088178; color: white; font-size: 16px; }
    #checkout-summary tr:nth-child(even) { background-color: #f2f2f2; }
    .checkout-total { font-size: 24px; font-weight: bold; color: #088178; margin: 20px 0; text-align:center; }
    .checkout-form { margin-top: 20px; }
    .checkout-form input {
      width: 100%; padding: 14px; margin: 10px 0; border: 1px solid #ccc; border-radius: 8px; font-size: 16px; box-sizing: border-box; transition: border 0.3s;
    }
    .checkout-form input:focus { border-color: #088178; outline: none; }
    .checkout-form button { background-color: #088178; color: white; font-size: 18px; font-weight: bold; padding: 16px; border: none; border-radius: 8px; cursor: pointer; transition: background 0.3s; width: 100%; display: block; margin-top: 10px; }
    .checkout-form button:hover { background-color: #066b64; }
    .empty-cart-msg { text-align: center; padding: 40px; color: #e63946; font-size: 20px; }
  </style>
</head>
<body>

  <%- include('./partials/header') %>
  <%- include('./partials/flash') %>
  <%- include('./partials/breadcrumbs') %>

  <div id="checkout-container">
    <h2><i class="fa-solid fa-bag-shopping"></i> Checkout</h2>

    <% if (cart && cart.length > 0) { %>
      <table id="checkout-summary">
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Subtotal</th>
        </tr>
        <% cart.forEach(item => { %>
          <tr>
            <td>
              <img src="/uploads/<%= item.image %>" width="50" height="50" style="border-radius:6px; object-fit:cover; margin-right:8px; vertical-align:middle;" onerror="this.src='/img/placeholder.jpg'">
              <%= item.name %>
            </td>
            <td>₹<%= item.price.toLocaleString('en-IN') %></td>
            <td><%= item.quantity %></td>
            <td>₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></td>
          </tr>
        <% }) %>
      </table>

        <h3 class="checkout-total" id="checkout-total-display" style="margin-top:10px; padding-top:10px; border-top:1px dashed #ddd;">
          Order Total: ₹<span id="grand-total-amount"><%= total.toLocaleString('en-IN') %></span>
          <% if (pointsUsed > 0) { %>
            <span style="font-size:14px; color:#088178; display:block; font-weight:500;">(Points Discount: -₹<%= pointsDiscount.toLocaleString('en-IN') %>)</span>
          <% } %>
        </h3>
        <p id="shipping-display" style="text-align:center; color:#e63946; font-weight:600; margin-top:5px;"></p>

      <% if (user && (user.loyaltyPoints > 0 || pointsUsed > 0)) { %>
        <div id="loyalty-section" class="loyalty-card" style="background:#f0f9f8; border:1px dashed #088178; padding:15px; border-radius:8px; margin:25px 0;">
          <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
            <div>
              <h5 style="margin:0; color:#088178; display:flex; align-items:center; gap:8px;">
                <i class="fa-solid fa-crown" style="font-size:18px;"></i> 
                EcomSphere Loyalty Points
              </h5>
              <p style="margin:5px 0 0; font-size:14px; color:#555;">
                Available Points: <strong id="available-points"><%= user.loyaltyPoints %></strong> 
                <span style="color:#888; font-size:12px; margin-left:8px;">(1 Point = ₹1.00)</span>
              </p>
            </div>
            <div id="loyalty-actions" class="<%= pointsUsed > 0 ? 'loyalty-hide' : 'loyalty-show' %>" style="gap:10px; align-items:center;">
              <input type="number" id="points-to-redeem" placeholder="Enter points" 
                     max="<%= user.loyaltyPoints %>" min="1"
                     style="width:110px; padding:8px 12px; border:1px solid #ddd; border-radius:4px; font-size:14px; outline:none;">
              <button type="button" id="apply-loyalty-btn" class="normal" 
                      style="background:#088178; color:#fff; padding:8px 18px; font-size:13px; border-radius:4px; cursor:pointer; font-weight:600;">
                Redeem
              </button>
            </div>
            <div id="loyalty-applied" class="<%= pointsUsed > 0 ? 'loyalty-show' : 'loyalty-hide' %>" style="align-items:center; gap:15px; background:rgba(8, 129, 120, 0.1); padding:8px 15px; border-radius:6px;">
               <span style="color:#088178; font-weight:700; font-size:14px;">
                 <i class="fa-solid fa-check-circle"></i> <span id="applied-points-text"><%= pointsUsed %></span> points applied!
               </span>
               <button type="button" id="remove-loyalty-btn" 
                       style="background:none; border:none; color:#ef4444; cursor:pointer; font-size:13px; text-decoration:underline;">
                 Remove
               </button>
            </div>
          </div>
        </div>
      <% } %>

      <form class="checkout-form" action="/checkout/place-order" method="POST" id="checkout-form">
        <input type="hidden" name="razorpay_payment_id" id="razorpay_payment_id">
        <input type="hidden" name="razorpay_order_id" id="razorpay_order_id">
        <input type="hidden" name="razorpay_signature" id="razorpay_signature">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; flex-wrap:wrap; gap:10px;">
          <h3 style="margin:0; color:#333;">Delivery Information</h3>
          
          <% if (user && user.addresses && user.addresses.length > 0) { %>
            <div style="display:flex; align-items:center; gap:10px;">
              <i class="fa-solid fa-location-dot" style="color:#088178;"></i>
              <select id="saved-address-selector" style="padding:8px 12px; border:1px solid #088178; border-radius:6px; cursor:pointer; background:#fff; font-size:14px; font-weight:600; color:#088178; outline:none;">
                <option value="">-- Use a Saved Address --</option>
                <% user.addresses.forEach((addr, idx) => { %>
                  <option value="<%= idx %>" <%= addr.isDefault ? 'selected' : '' %>>
                    <%= addr.isDefault ? '[Default] ' : '' %><%= addr.street %>, <%= addr.city %>
                  </option>
                <% }) %>
              </select>
            </div>
          <% } %>
        </div>

        <input type="text" name="name" id="delivery-name" placeholder="Full Name" required autocomplete="name">
        <input type="text" name="address" id="delivery-address" placeholder="Street Address & City" required autocomplete="street-address">
        <select name="state" id="delivery-state" required style="width: 100%; padding: 14px; margin: 10px 0; border: 1px solid #ccc; border-radius: 8px; font-size: 16px;">
            <option value="">-- Select Shipping Region --</option>
            <option value="MH">Maharashtra (Local)</option>
            <option value="DL">Delhi</option>
            <option value="KA">Karnataka</option>
            <option value="GJ">Gujarat</option>
            <option value="OTHER">Other State (National)</option>
        </select>
        <input type="tel" name="phone" id="delivery-phone" placeholder="Phone Number" required autocomplete="tel">
        
        <div style="margin: 20px 0; background: #fafafa; padding: 18px; border-radius: 8px; border: 1px solid #e0e0e0;">
          <h4 style="margin-top: 0; margin-bottom: 15px; color:#333; font-size:16px;"><i class="fa-solid fa-credit-card"></i> Payment Method</h4>
          <label style="display:flex; align-items:center; gap:8px; margin-bottom:12px; cursor:pointer; font-size:15px;">
            <input type="radio" name="paymentMethod" value="razorpay" checked style="width:auto; margin:0;"> 
            <span><strong>Online Payment</strong> (Card, UPI, Netbanking)</span>
          </label>
          <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-size:15px;">
            <input type="radio" name="paymentMethod" value="cod" style="width:auto; margin:0;"> 
            <span><strong>Cash on Delivery</strong> (Pay when you receive)</span>
          </label>
        </div>

        <button type="button" id="pay-btn">
          <i class="fa-solid fa-lock"></i> Pay Securely — ₹<%= total.toLocaleString('en-IN') %>
        </button>
      </form>

      <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
      <!-- Data source for script -->
      <script id="user-data" type="application/json">
        <%- JSON.stringify({
          addresses: user ? user.addresses || [] : [],
          username: user ? user.username : '',
          phone: user ? user.phone : ''
        }) %>
      </script>

      <script>
        // Saved Address Auto-fill Logic
        const userData = JSON.parse(document.getElementById('user-data').textContent);
        const addresses = userData.addresses;
        const nameInput = document.getElementById('delivery-name');
        const addressInput = document.getElementById('delivery-address');
        const phoneInput = document.getElementById('delivery-phone');
        const selector = document.getElementById('saved-address-selector');

        function fillAddress(idx) {
          if (idx !== "" && addresses[idx]) {
            const addr = addresses[idx];
            nameInput.value = userData.username; // Use username as fallback for saved name
            addressInput.value = `${addr.street}, ${addr.city}, ${addr.state} ${addr.zip}, ${addr.country}`;
            phoneInput.value = userData.phone;
          }
        }

        if (selector) {
          selector.addEventListener('change', function() {
            fillAddress(this.value);
            if (typeof updateShippingDisplay === 'function') updateShippingDisplay();
          });

          // Pre-fill on load if default exists
          if (selector.value !== "") {
            fillAddress(selector.value);
          }
          phoneInput.value = "<%= user ? user.phone : '' %>";
        }

        // Loyalty Points Logic
        const applyBtn = document.getElementById('apply-loyalty-btn');
        const removeBtn = document.getElementById('remove-loyalty-btn');
        const pointsInput = document.getElementById('points-to-redeem');
        const actionsDiv = document.getElementById('loyalty-actions');
        const appliedDiv = document.getElementById('loyalty-applied');
        const appliedText = document.getElementById('applied-points-text');

        if (applyBtn) {
          applyBtn.addEventListener('click', async () => {
            const points = pointsInput.value;
            if (!points || points <= 0) return alert('Please enter valid points');
            
            try {
              const res = await fetch('/api/cart/loyalty/apply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ points })
              });
              const data = await res.json();
              if (data.success) {
                appliedText.innerText = data.pointsUsed;
                actionsDiv.style.display = 'none';
                appliedDiv.style.display = 'flex';
                // Reload to update total or update DOM
                window.location.reload(); 
              } else {
                alert(data.error);
              }
            } catch (err) {
              console.error(err);
              alert('Error applying points');
            }
          });
        }

        if (removeBtn) {
          removeBtn.addEventListener('click', async () => {
            try {
              const res = await fetch('/api/cart/loyalty/remove', { method: 'POST' });
              const data = await res.json();
              if (data.success) {
                window.location.reload();
              }
            } catch (err) {
              console.error(err);
            }
          });
        }

        // --- DYNAMIC SHIPPING COST ---
        const stateInput = document.getElementById('delivery-state');
        const grandTotalSpan = document.getElementById('grand-total-amount');
        const shippingDisplay = document.getElementById('shipping-display');
        const baseTotal = <%= total %>;

        function updateShippingDisplay() {
            if (!stateInput) return;
            const state = stateInput.value;
            let shippingFee = 0;
            if (baseTotal > 1500) {
               shippingFee = 0;
            } else if (state === 'MH') {
               shippingFee = 50;
            } else if (state) {
               shippingFee = 100;
            }
            
            if (shippingFee > 0) {
                shippingDisplay.innerText = `+ ₹${shippingFee} Shipping Fee`;
                shippingDisplay.style.color = '#e63946';
            } else if (state) {
                shippingDisplay.innerText = `🎉 Eligible for Free Shipping!`;
                shippingDisplay.style.color = '#088178';
            } else {
                shippingDisplay.innerText = '';
            }
            
            grandTotalSpan.innerText = (baseTotal + shippingFee).toLocaleString('en-IN');
        }

        if (stateInput) {
            stateInput.addEventListener('change', updateShippingDisplay);
        }

        // --- RAZORPAY INTEGRATION ---
        const payBtn = document.getElementById('pay-btn');
        const checkoutForm = document.getElementById('checkout-form');
        
        if (payBtn) {
          payBtn.addEventListener('click', async () => {
            if (!nameInput.value || !addressInput.value || !phoneInput.value) {
              return alert('Please fill in all delivery details before paying.');
            }

            const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;

            if (paymentMethod === 'cod') {
               payBtn.innerText = 'Processing Order...';
               payBtn.disabled = true;
               checkoutForm.submit();
               return;
            }
            
            payBtn.innerText = 'Creating Secure Session...';
            payBtn.disabled = true;

            try {
              // 1. Ask backend to create order
              const res = await fetch('/checkout/razorpay/create', { 
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ state: stateInput.value })
              });
              const data = await res.json();

              if (!data.success) {
                  alert(data.error || 'Failed to initialize payment');
                  payBtn.innerHTML = '<i class="fa-solid fa-lock"></i> Pay Securely';
                  payBtn.disabled = false;
                  return;
              }

              // 2. Initialize Razorpay Checkout
              const options = {
                  key: data.key_id,
                  amount: data.amount,
                  currency: data.currency,
                  name: "EcomSphere",
                  description: "Order Checkout",
                  order_id: data.id,
                  prefill: {
                      name: nameInput.value,
                      contact: phoneInput.value,
                      email: "<%= user ? user.email : '' %>"
                  },
                  theme: { color: "#088178" },
                  handler: function (response) {
                      // 3. Payment Success - Append details and submit
                      document.getElementById('razorpay_payment_id').value = response.razorpay_payment_id;
                      document.getElementById('razorpay_order_id').value = response.razorpay_order_id;
                      document.getElementById('razorpay_signature').value = response.razorpay_signature;
                      
                      payBtn.innerText = 'Processing Order...';
                      checkoutForm.submit();
                  }
              };

              options.modal = {
                  ondismiss: function() {
                      payBtn.innerHTML = '<i class="fa-solid fa-lock"></i> Pay Securely';
                      payBtn.disabled = false;
                  }
              };

              const rzp = new Razorpay(options);
              rzp.on('payment.failed', function (response){
                  alert('Payment Failed: ' + response.error.description);
              });
              rzp.open();
              
            } catch (err) {
               console.error(err);
               alert('An error occurred during checkout');
               payBtn.innerHTML = '<i class="fa-solid fa-lock"></i> Pay Securely';
               payBtn.disabled = false;
            }
          });
        }
      </script>
    <% } else { %>
      <div class="empty-cart-msg">
        <i class="fa-solid fa-cart-shopping" style="font-size:60px; color:#ccc; display:block; margin-bottom:20px;"></i>
        <p>Your cart is empty!</p>
        <a href="/shop" style="display:inline-block;margin-top:15px;padding:12px 28px;background:#088178;color:#fff;border-radius:6px;text-decoration:none;font-weight:600;">Start Shopping</a>
      </div>
    <% } %>
  </div>

  <%- include('./partials/footer') %>

  <script src="/js/script.js"></script>
</body>
</html>
