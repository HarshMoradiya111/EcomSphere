<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Manage your EcomSphere profile">
  <title><%= title %></title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .profile-tabs { display: flex; list-style: none; padding: 0; margin-bottom: 30px; border-bottom: 2px solid #eee; overflow-x: auto; }
    .profile-tab { padding: 15px 25px; cursor: pointer; font-weight: 700; color: #666; transition: 0.3s; white-space: nowrap; border-bottom: 3px solid transparent; margin-bottom: -2px; }
    .profile-tab.active { color: #088178; border-bottom-color: #088178; }
    .tab-content { display: none; animation: fadeIn 0.4s ease; }
    .tab-content.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    
    .info-card { background: #fff; border: 1px solid #eee; border-radius: 12px; padding: 30px; margin-bottom: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); }
    .address-card { background: #fff; border: 1px solid #eee; border-radius: 10px; padding: 20px; margin-bottom: 15px; position: relative; }
    .address-card.default { border-color: #088178; background: #f0fff4; }
    .default-label { position: absolute; top: 10px; right: 15px; background: #088178; color: #fff; font-size: 10px; padding: 2px 8px; border-radius: 10px; text-transform: uppercase; }
    
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: #444; }
    .form-input { width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; transition: 0.3s; }
    .form-input:focus { border-color: #088178; box-shadow: 0 0 0 3px rgba(8, 129, 120, 0.1); }
  </style>
</head>
<body>

  <%- include('./partials/header') %>
  <%- include('./partials/flash') %>
  <%- include('./partials/breadcrumbs') %>

  <section id="page-header" class="about-header" style="background-image: url('/img/banner/b16.jpg');">
    <h2>Welcome, <%= user.username %>!</h2>
    <p>Manage your account, addresses and orders</p>
  </section>

  <section id="user-profile" class="section-p1">
    <div class="profile-container">
      
      <ul class="profile-tabs">
        <li class="profile-tab active" data-tab="overview">Overview</li>
        <li class="profile-tab" data-tab="edit-profile">Personal Info</li>
        <li class="profile-tab" data-tab="addresses">My Addresses</li>
        <li class="profile-tab" data-tab="orders">Order History</li>
      </ul>

      <!-- Overview Tab -->
      <div id="overview" class="tab-content active">
        <div style="display:flex; gap:40px; flex-wrap:wrap; align-items:flex-start;">
          <div class="info-card" style="flex:1; text-align:center; min-width:280px;">
            <img src="<%= user.profilePhoto || '/img/placeholder.jpg' %>" alt="Profile" 
                 onerror="this.src='/img/placeholder.jpg'" 
                 style="width:160px; height:160px; border-radius:50%; object-fit:cover; border: 5px solid #fff; box-shadow: 0 5px 20px rgba(0,0,0,0.1); margin-bottom:20px;">
            <h3 style="margin-bottom:5px;"><%= user.username %></h3>
            <p style="color:#888; font-size:14px; margin-bottom:20px;"><%= user.email %></p>
            
            <form action="/profile/photo" method="POST" enctype="multipart/form-data" id="photoForm">
              <label for="profilePhoto" class="normal" style="background:#088178; color:#fff; display:inline-block; font-size:12px; padding:10px 20px; cursor:pointer;">
                <i class="fa-solid fa-camera"></i> Change Photo
              </label>
              <input type="file" id="profilePhoto" name="profilePhoto" hidden onchange="this.form.submit()">
            </form>
          </div>

          <div class="info-card" style="flex:2; min-width:300px;">
            <h4 style="margin-bottom:20px; border-bottom:1px solid #eee; padding-bottom:10px;">Account Summary</h4>
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:20px;">
              <div>
                <p style="margin:0; color:#888; font-size:12px; text-transform:uppercase;">Member Since</p>
                <p style="margin:0; font-weight:700;"><%= new Date(user.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
              </div>
              <div>
                <p style="margin:0; color:#888; font-size:12px; text-transform:uppercase;">Total Orders</p>
                <p style="margin:0; font-weight:700;"><%= orders ? orders.length : 0 %></p>
              </div>
              <div>
                <p style="margin:0; color:#888; font-size:12px; text-transform:uppercase;">Phone</p>
                <p style="margin:0; font-weight:700;"><%= user.phone || 'Not provided' %></p>
              </div>
            </div>
            <div style="margin-top:30px;">
              <a href="/auth/logout" style="color:#dc3545; font-weight:700; text-decoration:none;"><i class="fa-solid fa-sign-out-alt"></i> Sign Out from this device</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Edit Profile Tab -->
      <div id="edit-profile" class="tab-content">
        <div class="info-card" style="max-width:600px;">
          <h4 style="margin-bottom:25px;">Update Personal Details</h4>
          <form action="/profile/update" method="POST">
            <div class="form-group">
              <label>Full Name / Username</label>
              <input type="text" name="username" class="form-input" value="<%= user.username %>" required>
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email" class="form-input" value="<%= user.email %>" required>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <input type="text" name="phone" class="form-input" value="<%= user.phone %>" placeholder="e.g. +91 9876543210">
            </div>
            <button type="submit" class="normal" style="background:#088178; color:#fff; width:100%;">Save Changes</button>
          </form>
        </div>
      </div>

      <!-- Addresses Tab -->
      <div id="addresses" class="tab-content">
        <div style="display:flex; gap:40px; flex-wrap:wrap; align-items:flex-start;">
          <!-- Address List -->
          <div style="flex:2; min-width:300px;">
            <h4 style="margin-bottom:20px;">My Saved Addresses</h4>
            <% if (user.addresses && user.addresses.length > 0) { %>
              <% user.addresses.forEach((addr, idx) => { %>
                <div class="address-card <%= addr.isDefault ? 'default' : '' %>">
                  <% if (addr.isDefault) { %>
                    <span class="default-label">Default</span>
                  <% } %>
                  <p style="margin:0; font-weight:700; color:#333;"><%= addr.street %></p>
                  <p style="margin:5px 0; color:#666; font-size:14px;"><%= addr.city %>, <%= addr.state %> <%= addr.zip %></p>
                  <p style="margin:0; color:#666; font-size:14px;"><%= addr.country %></p>
                  
                  <div style="margin-top:15px; border-top:1px solid #eee; padding-top:10px;">
                    <a href="/profile/address/delete/<%= idx %>" onclick="return confirm('Are you sure you want to delete this address?')" style="color:#dc3545; font-size:12px; font-weight:600; text-decoration:none;">
                      <i class="fa-solid fa-trash"></i> Delete
                    </a>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div style="padding:40px; background:#fff; border:1px dashed #ddd; border-radius:10px; text-align:center;">
                <p style="color:#888;">No saved addresses found.</p>
              </div>
            <% } %>
          </div>

          <!-- Add Address Form -->
          <div class="info-card" style="flex:1; min-width:320px;">
            <h4 style="margin-bottom:25px;">Add New Address</h4>
            <form action="/profile/address/add" method="POST">
              <div class="form-group">
                <label>Street Address</label>
                <input type="text" name="street" class="form-input" required>
              </div>
              <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                <div class="form-group">
                  <label>City</label>
                  <input type="text" name="city" class="form-input" required>
                </div>
                <div class="form-group">
                  <label>State</label>
                  <input type="text" name="state" class="form-input" required>
                </div>
              </div>
              <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                <div class="form-group">
                  <label>ZIP / Postal Code</label>
                  <input type="text" name="zip" class="form-input" required>
                </div>
                <div class="form-group">
                  <label>Country</label>
                  <input type="text" name="country" class="form-input" value="India">
                </div>
              </div>
              <div class="form-group" style="display:flex; align-items:center; gap:10px;">
                <input type="checkbox" name="isDefault" id="isDefault">
                <label for="isDefault" style="margin:0; cursor:pointer;">Set as default address</label>
              </div>
              <button type="submit" class="normal" style="background:#088178; color:#fff; width:100%;">Add Address</button>
            </form>
          </div>
        </div>
      </div>

      <!-- Orders Tab -->
      <div id="orders" class="tab-content">
        <% if (orders && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <div class="info-card" style="padding:25px;">
              <div style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:15px; border-bottom:1px solid #f0f0f0; padding-bottom:15px; margin-bottom:20px;">
                <div>
                  <h5 style="margin:0; color:#888; font-size:12px; text-transform:uppercase;">Order Placed</h5>
                  <p style="margin:0; font-weight:700;"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></p>
                </div>
                <div>
                  <h5 style="margin:0; color:#888; font-size:12px; text-transform:uppercase;">Total Amount</h5>
                  <p style="margin:0; font-weight:700;">₹<%= order.totalAmount.toLocaleString('en-IN') %></p>
                </div>
                <div>
                  <h5 style="margin:0; color:#888; font-size:12px; text-transform:uppercase;">Order ID</h5>
                  <p style="margin:0; font-weight:700;">#<%= order._id.toString().slice(-8).toUpperCase() %></p>
                </div>
                <div>
                  <span class="order-status status-<%= order.status.toLowerCase() %>" style="padding: 6px 16px; font-size: 13px;">
                    <%= order.status %>
                  </span>
                </div>
              </div>
              
              <div style="display:flex; gap:40px; flex-wrap:wrap;">
                <div style="flex:2; min-width:250px;">
                  <ul style="list-style:none; padding:0;">
                    <% order.items.forEach(item => { %>
                      <li style="display:flex; align-items:center; gap:15px; margin-bottom:15px; padding-bottom:15px; border-bottom:1px solid #f9f9f9;">
                        <img src="/uploads/<%= item.image %>" width="60" height="60" style="object-fit:cover; border-radius:8px;" onerror="this.src='/img/placeholder.jpg'">
                        <div>
                          <p style="margin:0; font-weight:700; font-size:14px;"><%= item.name %></p>
                          <p style="margin:2px 0; color:#777; font-size:12px;">Qty: <%= item.quantity %> | ₹<%= item.price.toLocaleString('en-IN') %></p>
                          <% if (item.size || item.color) { %>
                            <p style="margin:0; font-size:11px; color:#999;">
                              <%= item.size ? 'Size: ' + item.size : '' %> <%= item.color ? (item.size ? '| ' : '') + 'Color: ' + item.color : '' %>
                            </p>
                          <% } %>
                        </div>
                      </li>
                    <% }) %>
                  </ul>
                </div>
                <div style="flex:1; min-width:200px; padding:20px; background:#fbfbfb; border-radius:8px;">
                  <h5 style="margin-bottom:15px; font-size:14px;">Delivery Information</h5>
                  <p style="margin:0; font-size:14px; color:#444;"><strong><%= order.checkoutInfo.name %></strong></p>
                  <p style="margin:5px 0; font-size:13px; color:#666; line-height:1.5;"><%= order.checkoutInfo.address %></p>
                  <p style="margin:0; font-size:13px; color:#666;">Phone: <%= order.checkoutInfo.phone %></p>
                  
                  <div style="margin-top:20px; display:flex; flex-direction:column; gap:10px;">
                    <a href="/track-order?orderId=<%= order._id %>" class="normal" style="background:#088178; color:#fff; display:block; text-align:center; padding:10px; font-size:12px; text-decoration:none; border-radius:4px;">
                      <i class="fa-solid fa-map-marker-alt"></i> Live Tracking
                    </a>
                    <a href="/orders/invoice/<%= order._id %>" class="normal" style="background:#444; color:#fff; display:block; text-align:center; padding:10px; font-size:12px; text-decoration:none; border-radius:4px;">
                      <i class="fa-solid fa-file-pdf"></i> Download Invoice
                    </a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div style="text-align:center; padding:60px 20px; background:#fff; border:1px solid #eee; border-radius:12px;">
            <i class="fa-solid fa-shopping-bag" style="font-size:50px; color:#ccc; margin-bottom:20px; display:block;"></i>
            <p style="color:#888;">You haven't placed any orders yet.</p>
            <a href="/shop" class="normal" style="background:#088178; color:#fff; display:inline-block; margin-top:15px; text-decoration:none;">Browse Products</a>
          </div>
        <% } %>
      </div>

    </div>
  </section>

  <%- include('./partials/footer') %>

  <script src="/js/script.js"></script>
  <script>
    // Simple Tab Switching Logic
    document.querySelectorAll('.profile-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        // Remove active from all tabs
        document.querySelectorAll('.profile-tab').forEach(t => t.classList.remove('active'));
        // Hide all content
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        
        // Add active to current tab
        tab.classList.add('active');
        // Show current content
        const target = tab.dataset.tab;
        document.getElementById(target).classList.add('active');
        
        // Save active tab to URL hash (optional)
        window.location.hash = target;
      });
    });

    // Handle URL hash on load
    window.addEventListener('load', () => {
      const hash = window.location.hash.substring(1);
      if (hash) {
        const tab = document.querySelector(`.profile-tab[data-tab="${hash}"]`);
        if (tab) tab.click();
      }
    });

    // Trigger photo form
    document.getElementById('profilePhoto').addEventListener('change', function() {
      if(this.files[0]) document.getElementById('photoForm').submit();
    });
  </script>
</body>
</html>
