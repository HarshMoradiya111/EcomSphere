<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 - Page Not Found | EcomSphere</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <style>
    .error-container { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 20px; background: #fff; }
    .error-asset { max-width: 450px; width: 100%; margin-bottom: 30px; animation: float 6s ease-in-out infinite; }
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
    .error-title { font-size: 80px; font-weight: 900; color: #088178; margin: 0; line-height: 1; letter-spacing: -2px; }
    .error-sub { font-size: 28px; color: #1a1a1a; margin: 10px 0; font-weight: 700; }
    .error-text { font-size: 16px; color: #666; max-width: 500px; line-height: 1.6; margin-bottom: 40px; }
    .error-actions { display: flex; gap: 15px; flex-wrap: wrap; justify-content: center; }
    .btn-premium { background: #088178; color: #fff; padding: 15px 40px; border-radius: 40px; font-weight: bold; font-size: 15px; text-decoration: none; box-shadow: 0 10px 20px rgba(8, 129, 120, 0.2); transition: 0.3s; }
    .btn-premium:hover { background: #066b64; transform: translateY(-3px); box-shadow: 0 15px 30px rgba(8, 129, 120, 0.3); }
    .btn-outline { border: 2px solid #088178; color: #088178; padding: 13px 40px; border-radius: 40px; font-weight: bold; font-size: 15px; text-decoration: none; transition: 0.3s; }
    .btn-outline:hover { background: #088178; color: #fff; }
    .search-hint { margin-top: 50px; font-size: 14px; color: #999; }
    .search-hint a { color: #088178; text-decoration: none; font-weight: 600; }
  </style>
</head>
<body>
  <%- include('./partials/header') %>
  <%- include('./partials/flash') %>

  <div class="error-container">
    <div class="error-asset">
        <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#088178;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#066b64;stop-opacity:1" />
              </linearGradient>
            </defs>
            <circle cx="250" cy="250" r="200" fill="#f8f9fa"/>
            <!-- A magnifying glass with 404 look -->
            <path d="M150 250c0-55.2 44.8-100 100-100s100 44.8 100 100" stroke="url(#g)" stroke-width="20" fill="none" stroke-linecap="round"/>
            <circle cx="250" cy="250" r="20" fill="url(#g)"/>
            <path d="M250 250 L350 350" stroke="url(#g)" stroke-width="20" stroke-linecap="round"/>
        </svg>
    </div>
    
    <h1 class="error-title">404</h1>
    <h2 class="error-sub">Page has wandered off...</h2>
    <p class="error-text">We couldn't find the page you're looking for. It might have been moved, deleted, or never existed in the first place.</p>
    
    <div class="error-actions">
        <a href="/" class="btn-premium"><i class="fa-solid fa-house"></i> Go Home</a>
        <a href="/shop" class="btn-outline"><i class="fa-solid fa-cart-shopping"></i> Browse Shop</a>
    </div>

    <div class="search-hint">
        Need immediate help? <a href="/contact">Chat with us</a> or visit the <a href="/faq">Help Center</a>
    </div>
  </div>

  <%- include('./partials/footer') %>
</body>
</html>
