<%- include('./partials/admin_header', { activePage: 'dashboard' }) %>

<!-- Flash messages -->
<% if (locals.success && success.length > 0) { %>
  <div class="alert alert-success">
    <% success.forEach(msg => { %><p><i class="fa-solid fa-circle-check"></i> <%= msg %></p><% }) %>
  </div>
<% } %>
<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error">
    <% errors.forEach(msg => { %><p><i class="fa-solid fa-circle-exclamation"></i> <%= msg %></p><% }) %>
  </div>
<% } %>

<!-- Logistics Pipeline & Orders Matrix -->
<div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 30px;">
  <div class="stat-card" style="border-left: 5px solid #0ea5e9;">
    <div class="stat-info">
      <h3 style="color: #0ea5e9;"><%= statusCounts['Processing'] || 0 %></h3>
      <p>Processing Now</p>
    </div>
  </div>
  <div class="stat-card" style="border-left: 5px solid #8b5cf6;">
    <div class="stat-info">
      <h3 style="color: #8b5cf6;"><%= statusCounts['Shipped'] || 0 %></h3>
      <p>Out for Delivery</p>
    </div>
  </div>
  <div class="stat-card" style="border-left: 5px solid #22c55e;">
    <div class="stat-info">
      <h3 style="color: #22c55e;">₹<%= pipelineRevenue.toLocaleString('en-IN') %></h3>
      <p>Pipeline Value</p>
    </div>
  </div>
  <% if (zeroStockCount > 0) { %>
  <div class="stat-card" style="border-left: 5px solid #ef4444; background: #fff1f2;">
    <div class="stat-info">
      <h3 style="color: #ef4444;"><%= zeroStockCount %></h3>
      <p>Out of Stock Items</p>
    </div>
  </div>
  <% } %>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon" style="background:linear-gradient(135deg,#667eea,#764ba2);">
      <i class="fa-solid fa-box"></i>
    </div>
    <div class="stat-info">
      <h3><%= productCount %></h3>
      <p>Total Products</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:linear-gradient(135deg,#f093fb,#f5576c);">
      <i class="fa-solid fa-shopping-bag"></i>
    </div>
    <div class="stat-info">
      <h3><%= orderCount %></h3>
      <p>Total Orders</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:linear-gradient(135deg,#4facfe,#00f2fe);">
      <i class="fa-solid fa-users"></i>
    </div>
    <div class="stat-info">
      <h3><%= userCount %></h3>
      <p>Total Users</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:linear-gradient(135deg,#43e97b,#38f9d7);">
      <i class="fa-solid fa-chart-line"></i>
    </div>
    <div class="stat-info">
      <h3>Active</h3>
      <p>Store Status</p>
    </div>
  </div>
  <% if (lowStockCount > 0) { %>
    <a href="/admin/inventory" class="stat-card" style="border: 2px solid #ef4444; background: rgba(239, 68, 68, 0.05); text-decoration: none;">
      <div class="stat-icon" style="background:linear-gradient(135deg,#ff9a9e,#fecfef);">
        <i class="fa-solid fa-triangle-exclamation" style="color:#ef4444;"></i>
      </div>
      <div class="stat-info">
        <h3 style="color:#ef4444;"><%= lowStockCount %></h3>
        <p>Stock Alerts</p>
      </div>
    </a>
  <% } %>
</div>

<!-- Charts Section -->
<div class="charts-grid">
  <div class="admin-card" style="margin:0;">
    <div class="card-header">
      <h3>Revenue Overview (Last 7 Days)</h3>
    </div>
    <div style="padding:20px; height:300px;">
      <canvas id="revenueChart"></canvas>
    </div>
  </div>
  <div class="admin-card" style="margin:0;">
    <div class="card-header">
      <h3>Sales by Category (Last 30 Days)</h3>
    </div>
    <div style="padding:20px; height:300px; display:flex; justify-content:center;">
      <canvas id="categoryChart"></canvas>
    </div>
  </div>
</div>

  <div id="dashboard-data" 
       data-revenue="<%= JSON.stringify(dailyRevenue || []) %>" 
       data-categories="<%= JSON.stringify(categorySales || []) %>"
       style="display:none;"></div>


<script>
  // Prepare data from data attributes
  const dashboardData = document.getElementById('dashboard-data').dataset;
  const dailyRevenue = JSON.parse(dashboardData.revenue);
  const categorySales = JSON.parse(dashboardData.categories);

  // 1. Revenue Chart (Line)
  const revCtx = document.getElementById('revenueChart').getContext('2d');
  new Chart(revCtx, {
    type: 'line',
    data: {
      labels: dailyRevenue.map(d => new Date(d._id).toLocaleDateString('en-IN', { weekday: 'short', day: 'numeric' })),
      datasets: [{
        label: 'Revenue (₹)',
        data: dailyRevenue.map(d => d.revenue),
        borderColor: '#3b82f6',
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        fill: true,
        tension: 0.4,
        borderWidth: 3,
        pointBackgroundColor: '#3b82f6',
        pointRadius: 4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(255, 255, 255, 0.05)' },
          ticks: { color: '#94a3b8' }
        },
        x: {
          grid: { display: false },
          ticks: { color: '#94a3b8' }
        }
      }
    }
  });

  // 2. Category Chart (Doughnut)
  const catCtx = document.getElementById('categoryChart').getContext('2d');
  new Chart(catCtx, {
    type: 'doughnut',
    data: {
      labels: categorySales.map(c => c._id),
      datasets: [{
        data: categorySales.map(c => c.totalSold),
        backgroundColor: [
          '#3b82f6', '#22c55e', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899'
        ],
        borderWidth: 0,
        hoverOffset: 10
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { color: '#94a3b8', padding: 20, usePointStyle: true }
        }
      },
      cutout: '70%'
    }
  });
</script>

<!-- Quick Actions -->
<div class="quick-actions">
  <a href="/admin/products/add" class="admin-btn btn-primary">
    <i class="fa-solid fa-plus"></i> Add Product
  </a>
  <a href="/admin/orders" class="admin-btn btn-secondary">
    <i class="fa-solid fa-shopping-bag"></i> View Orders
  </a>
  <a href="/admin/users" class="admin-btn btn-secondary">
    <i class="fa-solid fa-users"></i> Manage Users
  </a>
</div>

<!-- Recent Orders -->
<% if (recentOrders && recentOrders.length > 0) { %>
<div class="admin-card" style="margin-top:30px;">
  <div class="card-header">
    <h3>Recent Orders</h3>
    <a href="/admin/orders" class="see-all">View All →</a>
  </div>
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Customer</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Date</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% recentOrders.forEach(order => { %>
          <tr>
            <td>#<%= order._id.toString().slice(-8).toUpperCase() %></td>
            <td><%= order.userId ? order.userId.username : 'Unknown' %></td>
            <td>₹<%= order.totalAmount.toLocaleString('en-IN') %></td>
            <td><span class="badge badge-<%= order.status.toLowerCase() %>"><%= order.status %></span></td>
            <td><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
            <td><a href="/admin/orders/<%= order._id %>" class="admin-btn btn-sm">View</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Top Sellers (Velocity) -->
<div class="admin-card" style="margin-top:30px;">
  <div class="card-header" style="background: linear-gradient(135deg, #0ea5e9, #2563eb); color: #fff; display: flex; justify-content: space-between; align-items: center;">
    <h3 style="color: #fff; margin: 0;"><i class="fa-solid fa-rocket"></i> Top Sellers (Product Velocity)</h3>
    <span style="opacity: 0.8; font-size: 14px;">High Performance Products</span>
  </div>
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Rank</th>
          <th>Product</th>
          <th>Units Sold</th>
          <th>Total Revenue</th>
          <th>Current Stock</th>
        </tr>
      </thead>
      <tbody>
        <% topSellers.forEach((item, index) => { %>
          <tr>
            <td><strong>#<%= index + 1 %></strong></td>
            <td>
              <div style="display:flex; align-items:center; gap:10px;">
                <img src="/uploads/<%= item.productInfo.image %>" width="40" height="40" style="border-radius:5px; object-fit:cover;" onerror="this.src='/img/placeholder.jpg'">
                <span><%= item.productInfo.name %></span>
              </div>
            </td>
            <td><span class="badge badge-category"><%= item.totalQuantity %> sold</span></td>
            <td>₹<%= item.revenue.toLocaleString('en-IN') %></td>
            <td>
              <% if ((item.productInfo.countInStock || 0) <= 5) { %>
                <span style="color: #ef4444; font-weight: bold;">
                  <%= item.productInfo.countInStock ?? 0 %> left
                </span>
              <% } else { %>
                <span style="color: #22c55e; font-weight: bold;">
                  <%= item.productInfo.countInStock ?? 0 %> left
                </span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Products Table -->
<div class="admin-card" style="margin-top:30px;">
  <div class="card-header">
    <h3>All Products</h3>
    <a href="/admin/products" class="see-all">View All →</a>
  </div>
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(product => { %>
          <tr>
            <td>
              <img src="/uploads/<%= product.image %>" alt="<%= product.name %>"
                class="product-thumb" onerror="this.src='/img/placeholder.jpg'">
            </td>
            <td><%= product.name %></td>
            <td><span class="badge badge-category"><%= product.category %></span></td>
            <td>₹<%= product.price.toLocaleString('en-IN') %></td>
            <td class="action-btns">
              <a href="/admin/products/edit/<%= product._id %>" class="admin-btn btn-warning btn-sm">
                <i class="fa-solid fa-pen-to-square"></i> Edit
              </a>
              <form action="/admin/products/delete/<%= product._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete this product?')">
                <button type="submit" class="admin-btn btn-danger btn-sm">
                  <i class="fa-solid fa-trash"></i> Delete
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('./partials/admin_footer') %>
