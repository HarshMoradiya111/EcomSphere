<%- include('./partials/admin_header', { activePage: 'products' }) %>

<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error"><% errors.forEach(msg => { %><p><%= msg %></p><% }) %></div>
<% } %>
<% if (locals.success && success.length > 0) { %>
  <div class="alert alert-success"><% success.forEach(msg => { %><p><%= msg %></p><% }) %></div>
<% } %>

<div class="admin-card" style="max-width:650px; margin:0 auto;">
  <div class="card-header">
    <h3><i class="fa-solid fa-pen-to-square"></i> Edit Product</h3>
    <a href="/admin/products" class="admin-btn btn-secondary btn-sm">← Back</a>
  </div>

  <!-- Current Image -->
  <div style="text-align:center; margin:20px 0;">
    <img src="/uploads/<%= product.image %>" alt="<%= product.name %>"
      style="width:150px; height:150px; object-fit:cover; border-radius:10px; border:2px solid #334155;"
      onerror="this.src='/img/placeholder.jpg'">
    <p style="color:#94a3b8; font-size:13px; margin-top:8px;">Current image</p>
  </div>

  <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="admin-form">
    <div class="form-group">
      <label for="edit-name">Product Name</label>
      <input type="text" id="edit-name" name="name" value="<%= product.name %>" required>
    </div>

    <div class="form-group">
      <label for="edit-category">Category</label>
      <select id="edit-category" name="category" required>
        <% categories.forEach(cat => { %>
          <option value="<%= cat %>" <%= product.category === cat ? 'selected' : '' %>><%= cat %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="edit-price">Price (₹)</label>
      <input type="number" id="edit-price" name="price" value="<%= product.price %>" min="0" step="0.01" required>
    </div>

    <div class="form-group">
      <label for="edit-description">Description</label>
      <textarea id="edit-description" name="description" rows="4" required><%= product.description %></textarea>
    </div>

    <div class="form-group">
      <label for="edit-image">New Image (optional)</label>
      <input type="file" id="edit-image" name="image" accept="image/*">
      <small style="color:#94a3b8; font-size:12px;">Leave blank to keep current image</small>
    </div>

    <div style="margin-top:20px; display:flex; gap:12px;">
      <button type="submit" class="admin-btn btn-primary" style="flex:1;">
        <i class="fa-solid fa-floppy-disk"></i> Save Changes
      </button>
      <a href="/admin/products" class="admin-btn btn-secondary" style="flex:1; text-align:center;">
        Cancel
      </a>
    </div>
  </form>
</div>

<%- include('./partials/admin_footer') %>
