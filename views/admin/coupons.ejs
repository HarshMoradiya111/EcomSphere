<%- include('./partials/admin_header', { activePage: 'coupons' }) %>

<div class="admin-header">
  <h2>Coupon Management</h2>
  <a href="/admin/coupons/add" class="admin-btn btn-primary">
    <i class="fa-solid fa-plus"></i> Add New Coupon
  </a>
</div>

<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error"><%= errors[0] %></div>
<% } %>
<% if (locals.success && success.length > 0) { %>
  <div class="alert alert-success"><%= success[0] %></div>
<% } %>

<div class="admin-card">
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Discount</th>
          <th>Min Purchase</th>
          <th>Expiry</th>
          <th>Usage</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (coupons && coupons.length > 0) { %>
          <% coupons.forEach(coupon => { %>
            <tr>
              <td><strong><%= coupon.code %></strong></td>
              <td>
                <%= coupon.discountValue %><%= coupon.discountType === 'percentage' ? '%' : '₹' %>
              </td>
              <td>₹<%= coupon.minPurchase %></td>
              <td>
                <span class="<%= new Date(coupon.expiryDate) < new Date() ? 'text-danger' : '' %>">
                  <%= new Date(coupon.expiryDate).toLocaleDateString() %>
                </span>
              </td>
              <td><%= coupon.usedCount %> / <%= coupon.usageLimit || '∞' %></td>
              <td>
                <span class="status-badge <%= coupon.isActive ? 'status-delivered' : 'status-cancelled' %>">
                  <%= coupon.isActive ? 'Active' : 'Inactive' %>
                </span>
              </td>
              <td>
                <div class="action-btns">
                  <a href="/admin/coupons/edit/<%= coupon._id %>" class="btn-icon text-primary" title="Edit">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </a>
                  <form action="/admin/coupons/delete/<%= coupon._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete this coupon?');">
                    <button type="submit" class="btn-icon text-danger" title="Delete">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" style="text-align:center; padding:30px; color:#888;">No coupons found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('./partials/admin_footer') %>
