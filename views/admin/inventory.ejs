<%- include('./partials/admin_header', { activePage: 'inventory' }) %>

<style>
  .stock-input { width: 80px; padding: 5px 10px; border: 1px solid #ddd; border-radius: 4px; text-align: center; }
  .low-stock-row { background-color: rgba(239, 68, 68, 0.05) !important; }
  .out-of-stock-row { background-color: rgba(239, 68, 68, 0.1) !important; }
  .save-stock-btn { background: #088178; color: #fff; border: none; border-radius: 4px; padding: 6px 12px; cursor: pointer; font-size: 12px; transition: 0.3s; }
  .save-stock-btn:hover { background: #066b64; }
  .save-stock-btn:disabled { background: #ccc; cursor: not-allowed; }
</style>

<!-- Flash messages -->
<% if (locals.success && success.length > 0) { %>
  <div class="alert alert-success">
    <% success.forEach(msg => { %><p><i class="fa-solid fa-circle-check"></i> <%= msg %></p><% }) %>
  </div>
<% } %>
<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error">
    <% errors.forEach(msg => { %><p><i class="fa-solid fa-circle-exclamation"></i> <%= msg %></p><% }) %>
  </div>
<% } %>

<div class="admin-card">
  <div class="card-header">
    <h3>Inventory Management</h3>
    <p style="font-size: 14px; color: #888;">Quickly monitor and update stock levels for all products</p>
  </div>
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Product Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Stock Count</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (products && products.length > 0) { %>
          <% products.forEach(product => { %>
            <tr id="row-<%= product._id %>" class="<%= product.countInStock === 0 ? 'out-of-stock-row' : (product.countInStock <= 5 ? 'low-stock-row' : '') %>">
              <td>
                <img src="/uploads/<%= product.image %>" alt="<%= product.name %>"
                  class="product-thumb" onerror="this.src='/img/placeholder.jpg'">
              </td>
              <td><strong><%= product.name %></strong></td>
              <td><span class="badge badge-category"><%= product.category %></span></td>
              <td>₹<%= product.price.toLocaleString('en-IN') %></td>
              <td>
                <input type="number" 
                       class="stock-input" 
                       id="input-<%= product._id %>" 
                       value="<%= product.countInStock %>" 
                       min="0"
                       onchange="enableSave('<%= product._id %>')">
              </td>
              <td>
                <span id="status-<%= product._id %>" class="badge badge-<%= product.status.toLowerCase().replace(/ /g, '-') %>">
                  <%= product.status %>
                </span>
              </td>
              <td>
                <button type="button" 
                        id="btn-<%= product._id %>" 
                        class="save-stock-btn" 
                        onclick="updateStock('<%= product._id %>')"
                        disabled>
                  Save
                </button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="7" style="text-align:center; padding:30px; color:#999;">No products found in inventory.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  function enableSave(id) {
    document.getElementById('btn-' + id).disabled = false;
  }

  async function updateStock(id) {
    const input = document.getElementById('input-' + id);
    const btn = document.getElementById('btn-' + id);
    const statusBadge = document.getElementById('status-' + id);
    const row = document.getElementById('row-' + id);
    const countInStock = input.value;

    try {
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
      btn.disabled = true;

      const response = await fetch('/admin/inventory/update-stock/' + id, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ countInStock })
      });

      const data = await response.json();

      if (data.success) {
        // Update UI
        statusBadge.innerHTML = data.newStatus;
        statusBadge.className = 'badge badge-' + data.newStatus.toLowerCase().replace(/ /g, '-');
        
        // Update Row style
        row.classList.remove('low-stock-row', 'out-of-stock-row');
        if (data.newStock === 0) row.classList.add('out-of-stock-row');
        else if (data.newStock <= 5) row.classList.add('low-stock-row');

        btn.innerHTML = 'Save';
        btn.disabled = true;

        // Visual feedback
        input.style.borderColor = '#22c55e';
        setTimeout(() => input.style.borderColor = '#ddd', 2000);
      } else {
        alert(data.message || 'Failed to update stock');
        btn.innerHTML = 'Save';
        btn.disabled = false;
      }
    } catch (e) {
      console.error(e);
      alert('Error updating stock');
      btn.innerHTML = 'Save';
      btn.disabled = false;
    }
  }
</script>

<%- include('./partials/admin_footer') %>
