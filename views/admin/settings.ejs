<%- include('./partials/admin_header') %>
    <section class='section-p1' style="padding: 40px;color:black; background: #fff; margin: 20px; border-radius: 8px;">
        <h2>Global Settings</h2>
        <form action='/admin/settings' method='POST' enctype='multipart/form-data'>
            <div style="margin-bottom: 15px;"><label style="display:block; margin-bottom:5px;">Address:</label><input
                    type='text' name='address' value='<%= settings.address %>' style="width: 100%; padding: 8px;"></div>
            <div style="margin-bottom: 15px;"><label style="display:block; margin-bottom:5px;">Phone:</label><input
                    type='text' name='phone' value='<%= settings.phone %>' style="width: 100%; padding: 8px;"></div>
            <div style="margin-bottom: 15px;"><label style="display:block; margin-bottom:5px;">Hours:</label><input
                    type='text' name='hours' value='<%= settings.hours %>' style="width: 100%; padding: 8px;"></div>
            <div style="margin-bottom: 15px;"><label style="display:block; margin-bottom:5px;">Email:</label><input
                    type='text' name='email' value='<%= settings.email %>' style="width: 100%; padding: 8px;"></div>
            <div style="margin-bottom: 15px;"><label style="display:block; margin-bottom:5px;">Website
                    Logo:</label><input type='file' name='logo' accept='image/*'></div>
            <button type='submit'
                style="padding: 10px 20px; background: #088178; color: #fff; border: none; border-radius: 4px; cursor: pointer;">Save
                Settings</button>
        </form>
    </section>
    </main>
    </div>
    <script src='/js/script.js'></script>
    </body>

    </html>