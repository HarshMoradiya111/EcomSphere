<%- include('./partials/admin_header', { activePage: 'products' }) %>

<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error"><% errors.forEach(msg => { %><p><i class="fa-solid fa-circle-exclamation"></i> <%= msg %></p><% }) %></div>
<% } %>

<div class="admin-card" style="max-width:650px; margin:0 auto;">
  <div class="card-header">
    <h3><i class="fa-solid fa-plus"></i> Add New Product</h3>
    <a href="/admin/products" class="admin-btn btn-secondary btn-sm">← Back</a>
  </div>

  <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="admin-form">
    <div class="form-group">
      <label for="prod-name">Product Name <span class="required">*</span></label>
      <input type="text" id="prod-name" name="name" placeholder="Enter product name" required>
    </div>

    <div class="form-group">
      <label for="prod-category">Category <span class="required">*</span></label>
      <select id="prod-category" name="category" required>
        <option value="">-- Select Category --</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat %>"><%= cat %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="prod-price">Price (₹) <span class="required">*</span></label>
      <input type="number" id="prod-price" name="price" placeholder="e.g. 1499" min="0" step="0.01" required>
    </div>

    <div class="form-group">
      <label for="prod-description">Description <span class="required">*</span></label>
      <textarea id="prod-description" name="description" rows="4" placeholder="Describe the product..." required></textarea>
    </div>

    <div class="form-group">
      <label for="prod-image">Product Image <span class="required">*</span></label>
      <input type="file" id="prod-image" name="image" accept="image/*" required>
      <small style="color:#94a3b8; font-size:12px;">Accepted: JPG, PNG, GIF, WEBP (max 5MB)</small>
    </div>

    <div style="margin-top:20px; display:flex; gap:12px;">
      <button type="submit" class="admin-btn btn-primary" style="flex:1;">
        <i class="fa-solid fa-floppy-disk"></i> Add Product
      </button>
      <a href="/admin/products" class="admin-btn btn-secondary" style="flex:1; text-align:center;">
        Cancel
      </a>
    </div>
  </form>
</div>

<%- include('./partials/admin_footer') %>
