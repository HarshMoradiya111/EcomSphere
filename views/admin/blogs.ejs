<%- include('./partials/admin_header') %>
  <section class='section-p1' style="padding: 40px;color:black  ; background: #fff; margin: 20px; border-radius: 8px;">
    <h2>Manage Blogs</h2>
    <a href='/admin/blogs/add'
      style="display: inline-block; margin-bottom: 20px; padding: 10px 20px; background: #088178; color: #fff; text-decoration: none; border-radius: 4px;">Add
      New Blog</a>
    <ul style="list-style: none; padding: 0;">
      <% blogs.forEach(b=> { %>
        <li style="padding: 15px; border-bottom: 1px solid #ccc; display: flex; justify-content: space-between;">
          <span><strong>
              <%= b.title %>
            </strong> - <%= new Date(b.date).toLocaleDateString() %></span>
          <div>
            <a href='/admin/blogs/edit/<%= b._id %>' style="color: #088178; margin-right: 15px;">Edit</a>
            <form method='POST' action='/admin/blogs/delete/<%= b._id %>?_method=DELETE' style='display:inline'>
              <button type='submit'
                style="background: none; border: none; color: red; cursor: pointer; text-decoration: underline;">Delete</button>
            </form>
          </div>
        </li>
        <% }) %>
    </ul>
  </section>
  </main>
  </div>
  <script src='/js/script.js'></script>
  </body>

  </html>