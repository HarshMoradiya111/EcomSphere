<%- include('./partials/admin_header') %>
  <section class='section-p1' style="padding: 40px;color:black  ; background: #fff; margin: 20px; border-radius: 8px;">
    <h2 style="padding-bottom: 10px;">Manage Blogs</h2>
    <a href='/admin/blogs/add'
      style="display: inline-block; margin-bottom: 20px; padding: 10px 20px; background: #088178; color: #fff; text-decoration: none; border-radius: 4px;">Add
      New Blog</a>
    <ul style="list-style: none; padding: 0;">
      <% blogs.forEach(b=> { %>
        <li
          style="padding: 15px; border-bottom: 1px solid #ccc; display: flex; justify-content: space-between; align-items: center;">
          <div style="display: flex; align-items: center; gap: 15px;">
            <img src="<%= b.image %>" alt="<%= b.title %>"
              style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;">
            <span>
              <strong>
                <%= b.title %>
              </strong><br>
              <small style="color: #666;">
                <%= new Date(b.date).toLocaleDateString() %>
              </small>
            </span>
          </div>
          <div>
            <a href='/admin/blogs/edit/<%= b._id %>'
              style="display: inline-block; margin-bottom: 20px; padding: 10px 20px; background: #088178; color: #fff; text-decoration: none; border-radius: 4px;">Edit</a>
            <form method='POST' action='/admin/blogs/delete/<%= b._id %>?_method=DELETE' style='display:inline' onsubmit="return confirm('Are you sure you want to permanently delete this blog?');">
              <button type='submit'
                style="display:inline-block; margin-bottom: 20px; padding:10px; text-decoration: none; color: rgb(248, 242, 242);background:red; border-radius:4px;">Delete</button>
            </form>
          </div>
        </li>
        <% }) %>
    </ul>
  </section>
  </main>
  </div>
  <script src='/js/script.js'></script>
  </body>

  </html>