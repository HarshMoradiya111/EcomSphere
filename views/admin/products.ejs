<%- include('./partials/admin_header', { activePage: 'products' }) %>

<% if (locals.success && success.length > 0) { %>
  <div class="alert alert-success"><% success.forEach(msg => { %><p><i class="fa-solid fa-circle-check"></i> <%= msg %></p><% }) %></div>
<% } %>
<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error"><% errors.forEach(msg => { %><p><i class="fa-solid fa-circle-exclamation"></i> <%= msg %></p><% }) %></div>
<% } %>

<div class="admin-card">
  <div class="card-header">
    <h3>All Products (<%= products.length %>)</h3>
    <a href="/admin/products/add" class="admin-btn btn-primary">
      <i class="fa-solid fa-plus"></i> Add New Product
    </a>
  </div>

  <div class="admin-filter-bar" style="background: #1e293b; padding: 15px 20px; border-bottom: 1px solid #334155; display: flex; gap: 15px; align-items: center; flex-wrap: wrap;">
    <form action="/admin/products" method="GET" style="display: flex; gap: 15px; width: 100%; align-items: center; flex-wrap: wrap;">
      
      <div style="display: flex; align-items: center; gap: 8px;">
        <label for="category" style="color: #cbd5e1; font-size: 14px; font-weight: 500;">Category:</label>
        <select name="category" id="category" class="admin-input" style="width: auto; padding: 8px 12px;">
          <option value="All" <%= selectedCategory === 'All' ? 'selected' : '' %>>All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= selectedCategory === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>

      <div style="display: flex; align-items: center; gap: 8px;">
        <label for="sort" style="color: #cbd5e1; font-size: 14px; font-weight: 500;">Sort By:</label>
        <select name="sort" id="sort" class="admin-input" style="width: auto; padding: 8px 12px;">
          <option value="newest" <%= selectedSort === 'newest' ? 'selected' : '' %>>Newest First</option>
          <option value="oldest" <%= selectedSort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
          <option value="price_desc" <%= selectedSort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
          <option value="price_asc" <%= selectedSort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
          <option value="name_asc" <%= selectedSort === 'name_asc' ? 'selected' : '' %>>Name: A to Z</option>
          <option value="name_desc" <%= selectedSort === 'name_desc' ? 'selected' : '' %>>Name: Z to A</option>
        </select>
      </div>

      <button type="submit" class="admin-btn btn-primary" style="padding: 8px 20px;">
        <i class="fa-solid fa-filter"></i> Filter
      </button>

      <% if (selectedCategory !== 'All' || selectedSort !== 'newest') { %>
        <a href="/admin/products" class="admin-btn btn-warning" style="padding: 8px 15px; margin-left: auto;">
          <i class="fa-solid fa-xmark"></i> Clear Filters
        </a>
      <% } %>
    </form>
  </div>

  <% if (products.length > 0) { %>
    <div class="table-responsive">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Added</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(product => { %>
            <tr>
              <td>
                <img src="/uploads/<%= product.image %>" alt="<%= product.name %>"
                  class="product-thumb" onerror="this.src='/img/placeholder.jpg'">
              </td>
              <td><%= product.name %></td>
              <td><span class="badge badge-category"><%= product.category %></span></td>
              <td>₹<%= product.price.toLocaleString('en-IN') %></td>
              <td><%= new Date(product.createdAt).toLocaleDateString('en-IN') %></td>
              <td class="action-btns">
                <a href="/admin/products/edit/<%= product._id %>" class="admin-btn btn-warning btn-sm">
                  <i class="fa-solid fa-pen-to-square"></i> Edit
                </a>
                <form action="/admin/products/delete/<%= product._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this product?')">
                  <button type="submit" class="admin-btn btn-danger btn-sm">
                    <i class="fa-solid fa-trash"></i> Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div style="text-align:center; padding:50px; color:#94a3b8;">
      <i class="fa-solid fa-box-open" style="font-size:50px; margin-bottom:15px;"></i>
      <p>No products yet. <a href="/admin/products/add" style="color:#ffd700;">Add your first product →</a></p>
    </div>
  <% } %>
</div>

<%- include('./partials/admin_footer') %>
