<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Shop All Products - EcomSphere">
  <title>
    <%= title %>
  </title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <%- include('./partials/header', { activePage: 'shop' }) %>
  <%- include('./partials/flash') %>
  <%- include('./partials/breadcrumbs') %>

      <section id="page-header">
        <h2>Shop All Products</h2>
        <p>Browse our complete collection</p>
      </section>

      <!-- Category Filter -->
      <style>
        .filter-btn {
          padding: 10px 22px;
          border-radius: 25px;
          text-decoration: none;
          font-weight: 600;
          font-size: 13px;
          transition: 0.3s;
          background: #f0f0f0;
          color: #333;
        }

        .filter-btn.active,
        .filter-btn:hover {
          background: #088178;
          color: #fff;
        }
      </style>
      <section class="section-p1" style="padding-bottom:10px;">
        <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center;">
          <a href="/shop" class="filter-btn <% if (!selectedCategory) { %>active<% } %>">
            All Products
          </a>
          <% categories.forEach(cat=> { %>
            <a href="/shop?category=<%= encodeURIComponent(cat) %>"
              class="filter-btn <% if (selectedCategory === cat) { %>active<% } %>">
              <%= cat %>
            </a>
            <% }) %>
        </div>
      </section>

      <section id="product1" class="section-p1">
        <% if (search) { %>
          <h2>Search Results for "<%= search %>"</h2>
          <% } else { %>
            <h2>
              <%= selectedCategory || 'All Products' %>
            </h2>
            <% } %>
              <p>
                <%= products.length %> product<%= products.length !==1 ? 's' : '' %> found
              </p>

              <div class="pro-container">
                <% if (products.length> 0) { %>
                  <% products.forEach(product=> { %>
                    <div class="pro">
                      <a href="/product/<%= product._id %>">
                        <img src="/uploads/<%= product.image %>" alt="<%= product.name %>"
                          onerror="this.src='/img/placeholder.jpg'">
                      </a>
                      <div class="des">
                        <span>
                          <%= product.category %>
                        </span>
                        <div class="star" style="margin: 5px 0;">
                          <% const avg = Math.round(product.averageRating || 0); %>
                          <% for(let i=1; i<=5; i++) { %>
                            <i class="fa-<%= i <= avg ? 'solid' : 'regular' %> fa-star" style="color: #ffbd27; font-size: 12px;"></i>
                          <% } %>
                          <small style="color: #888; margin-left: 5px;">(<%= product.numReviews || 0 %>)</small>
                        </div>
                        <h5>
                          <%= product.name %>
                        </h5>
                        <p>
                          <%= product.description.substring(0, 60) %>...
                        </p>
                        <h4>₹<%= product.price.toLocaleString('en-IN') %>
                        </h4>
                      </div>
                      <% if (locals.sessionUserId) { %>
                        <button class="toggle-wishlist <%= product.isInWishlist ? 'active' : '' %>"
                          data-product-id="<%= product._id %>" title="Wishlist"
                          style="position: absolute; top: 15px; right: 15px; background: rgba(255,255,255,0.9); border: none; border-radius: 50%; width: 35px; height: 35px; cursor: pointer; color: <%= product.isInWishlist ? '#ff4d4d' : '#ccc' %>; box-shadow: 0 4px 10px rgba(0,0,0,0.1); z-index: 10; display: flex; align-items: center; justify-content: center; transition: 0.3s;">
                          <i class="fa-solid fa-heart"></i>
                        </button>
                      <% } %>

                      <button class="compare-btn" onclick="addToCompare('<%= product._id %>')" title="Compare"
                        style="position: absolute; top: 60px; right: 15px; background: rgba(255,255,255,0.9); border: none; border-radius: 50%; width: 35px; height: 35px; cursor: pointer; color: #088178; box-shadow: 0 4px 10px rgba(0,0,0,0.1); z-index: 10; display: flex; align-items: center; justify-content: center; transition: 0.3s;">
                        <i class="fa-solid fa-scale-unbalanced-flip"></i>
                      </button>
                          <a href="#" class="add-to-cart cart1" data-product-id="<%= product._id %>"
                            data-name="<%= product.name %>" data-price="<%= product.price %>"
                            data-image="<%= product.image %>" title="Add to Cart">
                            <i class="fa-solid fa-cart-shopping"></i>
                          </a>
                    </div>
                    <% }) %>
                      <% } else { %>
                        <div style="text-align:center; width:100%; padding:60px 20px;">
                          <i class="fa-solid fa-magnifying-glass" style="font-size:60px; color:#ccc;"></i>
                          <p style="color:#888; margin-top:15px; font-size:18px;">No products found in this category.
                          </p>
                          <a href="/shop"
                            style="display:inline-block;margin-top:15px;padding:12px 28px;background:#088178;color:#fff;border-radius:6px;text-decoration:none;font-weight:600;">View
                            All Products</a>
                        </div>
                        <% } %>
              </div>
      </section>

      <%- include('./partials/footer') %>

        <script src="/js/script.js"></script>
</body>

</html>