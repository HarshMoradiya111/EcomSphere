<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Order Placed Successfully - EcomSphere">
  <title><%= title %></title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .success-container { max-width: 700px; margin: 60px auto; text-align: center; padding: 40px 30px; background: #fff; border-radius: 16px; box-shadow: 0 8px 30px rgba(0,0,0,0.08); }
    .success-icon { font-size: 80px; color: #28a745; margin-bottom: 20px; animation: bounceIn 0.6s ease; }
    @keyframes bounceIn { 0% { transform: scale(0); opacity: 0; } 60% { transform: scale(1.2); } 100% { transform: scale(1); opacity: 1; } }
    .success-container h2 { color: #28a745; font-size: 32px; margin-bottom: 10px; }
    .order-id { background: #f0fff4; border: 1px solid #28a745; border-radius: 8px; padding: 12px 20px; display: inline-block; margin: 15px 0; font-size: 16px; }
    .order-details { text-align: left; background: #f9f9f9; border-radius: 10px; padding: 20px; margin: 20px 0; }
    .order-details p { margin: 8px 0; }
    .item-list { list-style: none; padding: 0; margin: 10px 0; }
    .item-list li { padding: 8px 0; border-bottom: 1px solid #eee; display: flex; align-items: center; gap: 12px; }
    .item-list li:last-child { border-bottom: none; }
    .action-btns { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; margin-top: 25px; }
    .btn-primary-es { background: #088178; color: #fff; padding: 14px 30px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 15px; transition: 0.3s; }
    .btn-primary-es:hover { background: #066b64; }
    .btn-outline-es { background: #fff; color: #088178; padding: 13px 30px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 15px; border: 2px solid #088178; transition: 0.3s; }
    .btn-outline-es:hover { background: #088178; color: #fff; }
  </style>
</head>
<body>

  <%- include('./partials/header') %>

  <section class="section-p1">
    <div class="success-container">
      <div class="success-icon">
        <i class="fa-solid fa-circle-check"></i>
      </div>

      <h2>Order Placed Successfully!</h2>
      <p style="color:#666; font-size:17px;">Thank you for shopping with EcomSphere 🎉</p>

      <div class="order-id">
        <strong>Order ID:</strong> #<%= order._id.toString().slice(-8).toUpperCase() %>
      </div>

      <div class="order-details">
        <h3 style="margin-bottom:15px; color:#333;">Order Summary</h3>

        <ul class="item-list">
          <% order.items.forEach(item => { %>
            <li>
              <img src="/uploads/<%= item.image %>" width="50" height="50" style="border-radius:6px; object-fit:cover;" onerror="this.src='/img/placeholder.jpg'">
              <div>
                <strong><%= item.name %></strong><br>
                <small>Qty: <%= item.quantity %> × ₹<%= item.price.toLocaleString('en-IN') %></small>
              </div>
              <div style="margin-left:auto; font-weight:700; color:#088178;">
                ₹<%= (item.price * item.quantity).toLocaleString('en-IN') %>
              </div>
            </li>
          <% }) %>
        </ul>

        <hr style="margin:15px 0; border-color:#eee;">

        <p><strong>Total Amount:</strong> <span style="color:#088178; font-size:20px; font-weight:700;">₹<%= order.totalAmount.toLocaleString('en-IN') %></span></p>

        <% if (order.checkoutInfo) { %>
          <p><strong>Deliver to:</strong> <%= order.checkoutInfo.name %></p>
          <p><strong>Address:</strong> <%= order.checkoutInfo.address %></p>
          <p><strong>Phone:</strong> <%= order.checkoutInfo.phone %></p>
        <% } %>

        <p><strong>Order Status:</strong> <span class="order-status status-<%= order.status.toLowerCase() %>"><%= order.status %></span></p>
        <p><strong>Order Date:</strong> <%= new Date(order.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
      </div>

      <div class="action-btns">
        <a href="/" class="btn-primary-es"><i class="fa-solid fa-home"></i> Continue Shopping</a>
        <a href="/orders/invoice/<%= order._id %>" class="btn-primary-es" style="background:#444;"><i class="fa-solid fa-file-pdf"></i> Download Invoice</a>
        <a href="/profile" class="btn-outline-es"><i class="fa-solid fa-list-ul"></i> My Orders</a>
        <a href="/track-order?orderId=<%= order._id %>" class="btn-outline-es"><i class="fa-solid fa-map-location-dot"></i> Track Order</a>
      </div>
    </div>
  </section>

  <%- include('./partials/footer') %>

  <script src="/js/script.js"></script>
</body>
</html>
