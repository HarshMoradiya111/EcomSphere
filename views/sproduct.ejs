<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= product.name %> - EcomSphere">
  <title><%= title %></title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('./partials/header') %>
  <%- include('./partials/flash') %>

  <section id="prodetails" class="section-p1">
    <div class="single-pro-image" style="position: relative;">
      <img src="/uploads/<%= product.image %>"
           alt="<%= product.name %>"
           width="100%"
           id="main-product-image"
           onerror="this.src='/img/placeholder.jpg'">
      <button onclick="navigateImage(-1)" class="slider-btn" style="position: absolute; top: 45%; left: 10px; background: rgba(255,255,255,0.9); border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.1); padding: 12px 16px; border-radius: 50%; cursor: pointer; font-size: 16px; color: #222; transition: 0.3s; z-index: 5;"><i class="fa-solid fa-chevron-left"></i></button>
      <button onclick="navigateImage(1)" class="slider-btn" style="position: absolute; top: 45%; right: 10px; background: rgba(255,255,255,0.9); border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.1); padding: 12px 16px; border-radius: 50%; cursor: pointer; font-size: 16px; color: #222; transition: 0.3s; z-index: 5;"><i class="fa-solid fa-chevron-right"></i></button>
      <div class="small-img-group">
        <div class="small-img-col">
          <img src="/uploads/<%= product.image %>"
               alt="Main Image"
               class="small-img active-thumb"
               onerror="this.src='/img/placeholder.jpg'"
               onclick="changeImage(this)">
        </div>
        <% if (product.additionalImages && product.additionalImages.length > 0) { %>
          <% product.additionalImages.forEach(img => { %>
            <div class="small-img-col">
              <img src="/uploads/<%= img %>"
                   alt="Additional Image"
                   class="small-img"
                   onerror="this.style.display='none'"
                   onclick="changeImage(this)">
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div class="single-pro-details">
      <h6><%= product.category %></h6>
      <h2><%= product.name %></h2>
      <h4>₹<%= product.price.toLocaleString('en-IN') %></h4>
      <p><%= product.description %></p>

      <% if (product.category === 'Men Clothing' || product.category === 'Women Clothing') { %>
        <div style="margin:20px 0;">
          <label style="font-weight:600; margin-right:10px;">Size:</label>
          <select id="product-size" style="padding:8px 12px; border:1px solid #ddd; border-radius:4px; font-size: 15px; outline: none;">
            <option value="S">S</option>
            <option value="M" selected>M</option>
            <option value="L">L</option>
            <option value="XL">XL</option>
            <option value="XXL">XXL</option>
          </select>
        </div>
      <% } else if (product.category === 'Footwear') { %>
        <div style="margin:20px 0;">
          <label style="font-weight:600; margin-right:10px;">Size:</label>
          <select id="product-size" style="padding:8px 12px; border:1px solid #ddd; border-radius:4px; font-size: 15px; outline: none;">
            <option value="6">6</option>
            <option value="7">7</option>
            <option value="8" selected>8</option>
            <option value="9">9</option>
            <option value="10">10</option>
            <option value="11">11</option>
          </select>
        </div>
      <% } %>

      <div style="margin:20px 0;">
        <label style="font-weight:600; margin-right:10px;">Quantity:</label>
        <input type="number" id="product-quantity" value="1" min="1" max="10" style="width:60px; padding:8px; border:1px solid #ddd; border-radius:4px;">
      </div>

      <button
        class="add-to-cart normal"
        id="add-to-cart-btn"
        data-product-id="<%= product._id %>"
        data-name="<%= product.name %>"
        data-price="<%= product.price %>"
        data-image="<%= product.image %>"
        style="background:#088178; color:#fff; padding:14px 35px; border:none; border-radius:6px; font-size:15px; font-weight:600; cursor:pointer; transition:0.3s;">
        <i class="fa-solid fa-cart-shopping"></i> Add to Cart
      </button>

      <div style="margin-top:25px; padding-top:20px; border-top:1px solid #eee;">
        <p><i class="fa-solid fa-truck" style="color:#088178; margin-right:8px;"></i><strong>Free shipping</strong> on orders above ₹1000</p>
        <p><i class="fa-solid fa-rotate-left" style="color:#088178; margin-right:8px;"></i><strong>Free returns</strong> within 30 days</p>
        <p><i class="fa-solid fa-shield-halved" style="color:#088178; margin-right:8px;"></i><strong>Secure payment</strong> guaranteed</p>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  <% if (relatedProducts && relatedProducts.length > 0) { %>
  <section id="product1" class="section-p1">
    <h2>Related Products</h2>
    <p>More from <%= product.category %></p>
    <div class="pro-container">
      <% relatedProducts.forEach(rp => { %>
        <div class="pro">
          <a href="/product/<%= rp._id %>">
            <img src="/uploads/<%= rp.image %>" alt="<%= rp.name %>" onerror="this.src='/img/placeholder.jpg'">
          </a>
          <div class="des">
            <span><%= rp.category %></span>
            <h5><%= rp.name %></h5>
            <h4>₹<%= rp.price.toLocaleString('en-IN') %></h4>
          </div>
          <a href="#"
             class="add-to-cart cart1"
             data-product-id="<%= rp._id %>"
             data-name="<%= rp.name %>"
             data-price="<%= rp.price %>"
             data-image="<%= rp.image %>">
            <i class="fa-solid fa-cart-shopping"></i>
          </a>
        </div>
      <% }) %>
    </div>
  </section>
  <% } %>

  <%- include('./partials/footer') %>

  <script src="/js/script.js"></script>
  <script>
    function changeImage(element) {
      const mainImg = document.getElementById('main-product-image');
      
      // Don't animate if clicking the already active image
      if (mainImg.src === element.src) return;

      // Start fade out
      mainImg.style.opacity = 0;
      
      // Update active thumbnail styling
      document.querySelectorAll('.small-img').forEach(el => el.classList.remove('active-thumb'));
      element.classList.add('active-thumb');

      // Swap source and fade in after a tiny delay
      setTimeout(() => {
        mainImg.src = element.src;
        mainImg.style.opacity = 1;
      }, 150); // matches half of the CSS transition time for a smooth crossfade effect
    }

    function navigateImage(direction) {
      const thumbs = Array.from(document.querySelectorAll('.small-img'));
      if (thumbs.length <= 1) return; // No need to slide

      let currentIndex = thumbs.findIndex(el => el.classList.contains('active-thumb'));
      if (currentIndex === -1) currentIndex = 0;

      let nextIndex = currentIndex + direction;
      // Loop around
      if (nextIndex < 0) nextIndex = thumbs.length - 1;
      else if (nextIndex >= thumbs.length) nextIndex = 0;

      // Trigger the existing change function behavior on the next thumbnail
      changeImage(thumbs[nextIndex]);
      // Also scroll it into view if needed
      thumbs[nextIndex].parentElement.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    // Handle quantity-aware add to cart for single product page
    document.getElementById('add-to-cart-btn').addEventListener('click', function(e) {
      e.preventDefault();
      const qty = parseInt(document.getElementById('product-quantity').value) || 1;
      const sizeDropdown = document.getElementById('product-size');
      const size = sizeDropdown ? sizeDropdown.value : null;
      const productId = this.dataset.productId;

      fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, quantity: qty, size: size })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast('Item added to cart! 🛒');
        } else {
          showToast(data.error || 'Failed to add item', 'error');
        }
      })
      .catch(() => showToast('Error adding to cart', 'error'));
    });
  </script>
</body>
</html>
