<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= product.name %> - EcomSphere">
  <title><%= title %></title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('./partials/header') %>
  <%- include('./partials/flash') %>

  <section id="prodetails" class="section-p1">
    <div class="single-pro-image" style="position: relative;">
      <img src="/uploads/<%= product.image %>"
           alt="<%= product.name %>"
           width="100%"
           id="main-product-image"
           onerror="this.src='/img/placeholder.jpg'">
      <button onclick="navigateImage(-1)" class="slider-btn" style="position: absolute; top: 45%; left: 10px; background: rgba(255,255,255,0.9); border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.1); padding: 12px 16px; border-radius: 50%; cursor: pointer; font-size: 16px; color: #222; transition: 0.3s; z-index: 5;"><i class="fa-solid fa-chevron-left"></i></button>
      <button onclick="navigateImage(1)" class="slider-btn" style="position: absolute; top: 45%; right: 10px; background: rgba(255,255,255,0.9); border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.1); padding: 12px 16px; border-radius: 50%; cursor: pointer; font-size: 16px; color: #222; transition: 0.3s; z-index: 5;"><i class="fa-solid fa-chevron-right"></i></button>
      <div class="small-img-group">
        <div class="small-img-col">
          <img src="/uploads/<%= product.image %>"
               alt="Main Image"
               class="small-img active-thumb"
               onerror="this.src='/img/placeholder.jpg'"
               onclick="changeImage(this)">
        </div>
        <% if (product.additionalImages && product.additionalImages.length > 0) { %>
          <% product.additionalImages.forEach(img => { %>
            <div class="small-img-col">
              <img src="/uploads/<%= img %>"
                   alt="Additional Image"
                   class="small-img"
                   onerror="this.style.display='none'"
                   onclick="changeImage(this)">
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div class="single-pro-details">
      <h6><%= product.category %></h6>
      <h2><%= product.name %></h2>
      <h4>₹<%= product.price.toLocaleString('en-IN') %></h4>
      <div class="stock-status" style="margin-bottom: 20px;">
        <span class="order-status status-<%= (product.status || 'In Stock').toLowerCase().replace(/ /g, '-') %>">
          <i class="fa-solid <%= product.countInStock > 0 ? 'fa-check-circle' : 'fa-circle-xmark' %>"></i>
          <%= product.status || 'In Stock' %> 
          <% if (product.countInStock > 0 && product.countInStock <= 5) { %>
            (<%= product.countInStock %> left)
          <% } %>
        </span>
      </div>

      <p><%= product.description %></p>

      <% if (product.sizes && product.sizes.length > 0) { %>
        <div style="margin:20px 0;">
          <label style="font-weight:600; margin-right:10px;">Size:</label>
          <select id="product-size" style="padding:8px 12px; border:1px solid #ddd; border-radius:4px; font-size: 15px; outline: none;">
            <% product.sizes.forEach(size => { %>
              <option value="<%= size %>"><%= size %></option>
            <% }) %>
          </select>
        </div>
      <% } %>
 
      <% if (product.colors && product.colors.length > 0) { %>
        <div style="margin:20px 0;">
          <label style="font-weight:600; margin-right:10px;">Color:</label>
          <select id="product-color" style="padding:8px 12px; border:1px solid #ddd; border-radius:4px; font-size: 15px; outline: none;">
            <% product.colors.forEach(color => { %>
              <option value="<%= color %>"><%= color %></option>
            <% }) %>
          </select>
        </div>
      <% } %>

      <div style="margin:20px 0;">
        <label style="font-weight:600; margin-right:10px;">Quantity:</label>
        <input type="number" id="product-quantity" value="1" min="1" max="10" style="width:60px; padding:8px; border:1px solid #ddd; border-radius:4px;">
      </div>

      <button
        class="add-to-cart normal"
        id="add-to-cart-btn"
        data-product-id="<%= product._id %>"
        data-name="<%= product.name %>"
        data-price="<%= product.price %>"
        data-image="<%= product.image %>"
        <%= product.countInStock === 0 ? 'disabled' : '' %>
        style="background: <%= product.countInStock === 0 ? '#ccc' : '#088178' %>; color:#fff; padding:14px 35px; border:none; border-radius:6px; font-size:15px; font-weight:600; cursor: <%= product.countInStock === 0 ? 'not-allowed' : 'pointer' %>; transition:0.3s;">
        <i class="fa-solid fa-cart-shopping"></i> <%= product.countInStock === 0 ? 'Out of Stock' : 'Add to Cart' %>
      </button>

      <div style="margin-top:25px; padding-top:20px; border-top:1px solid #eee;">
        <p><i class="fa-solid fa-truck" style="color:#088178; margin-right:8px;"></i><strong>Free shipping</strong> on orders above ₹1000</p>
        <p><i class="fa-solid fa-rotate-left" style="color:#088178; margin-right:8px;"></i><strong>Free returns</strong> within 30 days</p>
        <p><i class="fa-solid fa-shield-halved" style="color:#088178; margin-right:8px;"></i><strong>Secure payment</strong> guaranteed</p>
      </div>
    </div>
  </section>
 
  <!-- Product Reviews Section -->
  <section id="reviews" class="section-p1">
    <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:40px;">
      
      <!-- Show Reviews -->
      <div style="flex:2; min-width:320px;">
        <h3 style="margin-bottom:20px;">Customer Reviews (<%= product.numReviews %>)</h3>
        
        <div style="display:flex; align-items:center; gap:20px; margin-bottom:35px; background: #fbfbfb; padding: 25px; border-radius: 12px; border: 1px solid #f0f0f0;">
          <h1 style="font-size:54px; color:#088178; margin:0; line-height: 1;"><%= product.averageRating %></h1>
          <div>
            <div class="stars" style="color:#ffbd27; font-size:20px; margin-bottom: 5px;">
              <% for(let i=1; i<=5; i++) { %>
                <i class="fa-<%= i <= Math.round(product.averageRating) ? 'solid' : 'regular' %> fa-star"></i>
              <% } %>
            </div>
            <p style="color:#777; margin:0; font-weight: 500;">Average Rating</p>
          </div>
        </div>
 
        <div id="reviews-list">
          <% if (product.reviews && product.reviews.length > 0) { %>
            <% product.reviews.sort((a,b) => new Date(b.createdAt) - new Date(a.createdAt)).forEach(review => { %>
              <div class="review-item" style="padding:25px 0; border-top:1px solid #eee;">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                  <img src="<%= review.userPhoto || '/img/rprofile/1.jpg' %>" alt="User" style="width:45px; height:45px; border-radius:50%; object-fit:cover; border: 1px solid #eee;">
                  <div>
                    <h5 style="margin:0; font-size: 15px;"><%= review.username %></h5>
                    <div class="stars" style="color:#ffbd27; font-size:11px; margin-top: 2px;">
                      <% for(let i=1; i<=5; i++) { %>
                        <i class="fa-solid fa-star review-star <%= i <= review.rating ? 'active' : '' %>"></i>
                      <% } %>
                    </div>
                  </div>
                  <small style="color:#999; margin-left:auto;"><%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></small>
                </div>
                <p style="color:#444; line-height:1.7; margin:0; font-size: 14.5px;"><%= review.comment %></p>
              </div>
            <% }) %>
          <% } else { %>
            <div style="text-align:center; padding: 40px; background: #fff; border: 1px dashed #ddd; border-radius: 8px;">
              <i class="fa-regular fa-comment-dots" style="font-size: 40px; color: #ddd; margin-bottom: 10px; display: block;"></i>
              <p style="color:#888; margin: 0;">No reviews yet. Be the first to share your thoughts!</p>
            </div>
          <% } %>
        </div>
      </div>
 
      <!-- Add Review Form -->
      <div style="flex:1; min-width:320px; background:#fff; padding:35px; border-radius:12px; border: 1px solid #eee; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
        <h3 style="margin-bottom:25px; font-size: 20px;">Write a Review</h3>
        <form id="add-review-form">
          <input type="hidden" id="review-product-id" value="<%= product._id %>">
          
          <div style="margin-bottom:25px;">
            <label style="display:block; margin-bottom:12px; font-weight:600; font-size: 14px; color: #555;">Rating</label>
            <div id="star-rating" style="display:flex; gap:10px; font-size:28px; color:#ddd; cursor:pointer;">
              <i class="fa-solid fa-star star-opt" data-value="1"></i>
              <i class="fa-solid fa-star star-opt" data-value="2"></i>
              <i class="fa-solid fa-star star-opt" data-value="3"></i>
              <i class="fa-solid fa-star star-opt" data-value="4"></i>
              <i class="fa-solid fa-star star-opt" data-value="5"></i>
            </div>
            <input type="hidden" id="review-rating" value="0">
          </div>
 
          <div style="margin-bottom:25px;">
            <label style="display:block; margin-bottom:12px; font-weight:600; font-size: 14px; color: #555;">Your Comment</label>
            <textarea id="review-comment" rows="5" style="width:100%; padding:15px; border:1px solid #eee; background: #fcfcfc; border-radius:8px; outline:none; font-family: inherit; font-size: 14px; transition: 0.3s; resize: none;" 
                      placeholder="Share your experience with this product..." required></textarea>
          </div>
 
          <button type="submit" class="normal" id="submit-review-btn" style="background:#088178; color:#fff; border:none; padding:15px 30px; border-radius:8px; font-weight:700; cursor:pointer; width:100%; font-size: 15px; transition: 0.3s; box-shadow: 0 4px 12px rgba(8, 129, 120, 0.2);">
            Submit Review
          </button>
        </form>
      </div>
 
    </div>
  </section>
 
  <!-- Related Products -->
  <% if (relatedProducts && relatedProducts.length > 0) { %>
  <section id="product1" class="section-p1">
    <h2>Related Products</h2>
    <p>More from <%= product.category %></p>
    <div class="pro-container">
      <% relatedProducts.forEach(rp => { %>
        <div class="pro">
          <a href="/product/<%= rp._id %>">
            <img src="/uploads/<%= rp.image %>" alt="<%= rp.name %>" onerror="this.src='/img/placeholder.jpg'">
          </a>
          <div class="des">
            <span><%= rp.category %></span>
            <h5><%= rp.name %></h5>
            <h4>₹<%= rp.price.toLocaleString('en-IN') %></h4>
          </div>
          <a href="#"
             class="add-to-cart cart1"
             data-product-id="<%= rp._id %>"
             data-name="<%= rp.name %>"
             data-price="<%= rp.price %>"
             data-image="<%= rp.image %>">
            <i class="fa-solid fa-cart-shopping"></i>
          </a>
        </div>
      <% }) %>
    </div>
  </section>
  <% } %>

  <%- include('./partials/footer') %>

  <script src="/js/script.js"></script>
  <script>
    // Star Rating Interaction
    const starOpts = document.querySelectorAll('.star-opt');
    const ratingInput = document.getElementById('review-rating');
 
    starOpts.forEach(star => {
      star.addEventListener('click', function() {
        const val = this.dataset.value;
        ratingInput.value = val;
        
        // Update visual
        starOpts.forEach(s => {
          if (s.dataset.value <= val) {
            s.style.color = '#ffbd27';
          } else {
            s.style.color = '#ddd';
          }
        });
      });
 
      // Hover effect
      star.addEventListener('mouseover', function() {
        const val = this.dataset.value;
        starOpts.forEach(s => {
          if (s.dataset.value <= val) s.style.color = '#ffbd27';
        });
      });
 
      star.addEventListener('mouseout', function() {
        const val = ratingInput.value;
        starOpts.forEach(s => {
          if (s.dataset.value <= val) s.style.color = '#ffbd27';
          else s.style.color = '#ddd';
        });
      });
    });
 
    // Submit Review
    const reviewForm = document.getElementById('add-review-form');
    if (reviewForm) {
      reviewForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const productId = document.getElementById('review-product-id').value;
        const rating = ratingInput.value;
        const comment = document.getElementById('review-comment').value;
 
        if (rating == 0) {
          showToast('Please select a star rating', 'error');
          return;
        }
 
        const btn = document.getElementById('submit-review-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Submitting...';
 
        try {
          const response = await fetch('/api/product/review', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId, rating, comment })
          });
 
          const data = await response.json();
          
          if (data.success) {
            showToast('Review submitted successfully! Thank you.');
            // Dynamically add the review to the list
            const reviewList = document.getElementById('reviews-list');
            const noReviewsMsg = reviewList.querySelector('div[style*="dashed"]');
            if (noReviewsMsg) noReviewsMsg.remove();
 
            const newReviewHtml = `
              <div class="review-item" style="padding:25px 0; border-top:1px solid #eee; animation: fadeIn 0.5s ease;">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                  <img src="${data.review.userPhoto || '/img/rprofile/1.jpg'}" alt="User" style="width:45px; height:45px; border-radius:50%; object-fit:cover; border: 1px solid #eee;">
                  <div>
                    <h5 style="margin:0; font-size: 15px;">${data.review.username}</h5>
                    <div class="stars" style="color:#ffbd27; font-size:11px; margin-top: 2px;">
                      ${Array(5).fill(0).map((_, i) => `<i class="fa-solid fa-star review-star ${i + 1 <= data.review.rating ? 'active' : ''}"></i>`).join('')}
                    </div>
                  </div>
                  <small style="color:#999; margin-left:auto;">${data.review.createdAt}</small>
                </div>
                <p style="color:#444; line-height:1.7; margin:0; font-size: 14.5px;">${data.review.comment}</p>
              </div>
            `;
            reviewList.insertAdjacentHTML('afterbegin', newReviewHtml);
            
            // Clear form
            reviewForm.reset();
            ratingInput.value = 0;
            starOpts.forEach(s => s.style.color = '#ddd');
            
            // Update counts (optional but nice)
            const countHeader = document.querySelector('#reviews h3');
            if (countHeader) countHeader.textContent = `Customer Reviews (${data.numReviews})`;
          } else {
            showToast(data.error || 'Failed to submit review', 'error');
          }
        } catch (err) {
          console.error('Submit review error:', err);
          showToast('An error occurred. Please try again.', 'error');
        } finally {
          btn.disabled = false;
          btn.innerHTML = 'Submit Review';
        }
      });
    }
 
    function changeImage(element) {
      const mainImg = document.getElementById('main-product-image');
      
      // Don't animate if clicking the already active image
      if (mainImg.src === element.src) return;

      // Start fade out
      mainImg.style.opacity = 0;
      
      // Update active thumbnail styling
      document.querySelectorAll('.small-img').forEach(el => el.classList.remove('active-thumb'));
      element.classList.add('active-thumb');

      // Swap source and fade in after a tiny delay
      setTimeout(() => {
        mainImg.src = element.src;
        mainImg.style.opacity = 1;
      }, 150); // matches half of the CSS transition time for a smooth crossfade effect
    }

    function navigateImage(direction) {
      const thumbs = Array.from(document.querySelectorAll('.small-img'));
      if (thumbs.length <= 1) return; // No need to slide

      let currentIndex = thumbs.findIndex(el => el.classList.contains('active-thumb'));
      if (currentIndex === -1) currentIndex = 0;

      let nextIndex = currentIndex + direction;
      // Loop around
      if (nextIndex < 0) nextIndex = thumbs.length - 1;
      else if (nextIndex >= thumbs.length) nextIndex = 0;

      // Trigger the existing change function behavior on the next thumbnail
      changeImage(thumbs[nextIndex]);
      // Also scroll it into view if needed
      thumbs[nextIndex].parentElement.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    // Handle quantity-aware add to cart for single product page
    document.getElementById('add-to-cart-btn').addEventListener('click', function(e) {
      e.preventDefault();
      const qty = parseInt(document.getElementById('product-quantity').value) || 1;
      const sizeDropdown = document.getElementById('product-size');
      const size = sizeDropdown ? sizeDropdown.value : null;
      const colorDropdown = document.getElementById('product-color');
      const color = colorDropdown ? colorDropdown.value : null;
      const productId = this.dataset.productId;

      fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, quantity: qty, size: size, color: color })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast('Item added to cart! 🛒');
        } else {
          showToast(data.error || 'Failed to add item', 'error');
        }
      })
      .catch(() => showToast('Error adding to cart', 'error'));
    });
  </script>
</body>
</html>
