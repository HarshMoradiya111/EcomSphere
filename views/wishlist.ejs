<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="My Wishlist - EcomSphere">
  <title><%= title %></title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('./partials/header', { activePage: 'wishlist' }) %>
  <%- include('./partials/flash') %>

  <section id="page-header" class="about-header" style="background-image: url('/img/banner/b16.jpg');">
    <h2>My Wishlist</h2>
    <p>Saved items you love</p>
  </section>

  <section id="product1" class="section-p1">
    <div class="pro-container">
      <% if (wishlist.length > 0) { %>
        <% wishlist.forEach(product => { %>
          <div class="pro">
            <a href="/product/<%= product._id %>">
              <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" onerror="this.src='/img/placeholder.jpg'">
            </a>
            <div class="des">
              <span><%= product.category %></span>
              <h5><%= product.name %></h5>
              <p><%= product.description.substring(0, 60) %>...</p>
              <h4>₹<%= product.price.toLocaleString('en-IN') %></h4>
            </div>
            <!-- Heart Toggle -->
            <button class="toggle-wishlist active" 
                    data-product-id="<%= product._id %>" 
                    title="Remove from Wishlist" 
                    style="position: absolute; top: 15px; right: 15px; background: rgba(255,255,255,0.9); border: none; border-radius: 50%; width: 35px; height: 35px; cursor: pointer; color: #ff4d4d; box-shadow: 0 4px 10px rgba(0,0,0,0.1); z-index: 10; display: flex; align-items: center; justify-content: center; transition: 0.3s;">
              <i class="fa-solid fa-heart"></i>
            </button>
            <a href="#" class="add-to-cart cart1" data-product-id="<%= product._id %>" data-name="<%= product.name %>" data-price="<%= product.price %>" data-image="<%= product.image %>" title="Add to Cart">
              <i class="fa-solid fa-cart-shopping"></i>
            </a>
          </div>
        <% }) %>
      <% } else { %>
        <div style="text-align:center; width:100%; padding:60px 20px;">
          <i class="fa-regular fa-heart" style="font-size:60px; color:#ccc;"></i>
          <p style="color:#888; margin-top:15px; font-size:18px;">Your wishlist is empty.</p>
          <a href="/shop" style="display:inline-block;margin-top:15px;padding:12px 28px;background:#088178;color:#fff;border-radius:6px;text-decoration:none;font-weight:600;">Go to Shop</a>
        </div>
      <% } %>
    </div>
  </section>

  <%- include('./partials/footer') %>

  <script src="/js/script.js"></script>
  <script>
    document.querySelectorAll('.toggle-wishlist').forEach(btn => {
      btn.addEventListener('click', async function(e) {
        e.preventDefault();
        const productId = this.dataset.productId;
        try {
          const response = await fetch('/api/wishlist/toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId })
          });
          const data = await response.json();
          if (data.success) {
            this.closest('.pro').style.opacity = '0';
            setTimeout(() => {
              this.closest('.pro').remove();
              if (document.querySelectorAll('.pro').length === 0) {
                window.location.reload();
              }
            }, 300);
          }
        } catch (err) {
          console.error('Error toggling wishlist:', err);
        }
      });
    });
  </script>
</body>
</html>
