<%- include('./partials/admin_header', { activePage: 'orders' }) %>

<% if (locals.success && success.length > 0) { %>
  <div class="alert alert-success"><% success.forEach(msg => { %><p><%= msg %></p><% }) %></div>
<% } %>
<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error"><% errors.forEach(msg => { %><p><%= msg %></p><% }) %></div>
<% } %>

<div style="display:flex; gap:20px; flex-wrap:wrap;">
  <!-- Order Info Card -->
  <div class="admin-card" style="flex:1; min-width:300px;">
    <div class="card-header">
      <h3>Order Details</h3>
      <div style="display:flex; gap:10px;">
        <a href="/orders/invoice/<%= order._id %>" class="admin-btn btn-primary btn-sm">
          <i class="fa-solid fa-file-pdf"></i> Invoice
        </a>
        <a href="/admin/orders" class="admin-btn btn-secondary btn-sm">← Back</a>
      </div>
    </div>

    <div style="padding:10px 0;">
      <p><strong>Order ID:</strong> #<%= order._id.toString().slice(-8).toUpperCase() %></p>
      <p><strong>Date:</strong> <%= new Date(order.createdAt).toLocaleDateString('en-IN', { year:'numeric', month:'long', day:'numeric', hour:'2-digit', minute:'2-digit' }) %></p>
      <p><strong>Status:</strong> <span class="badge badge-<%= order.status.toLowerCase() %>"><%= order.status %></span></p>
      <p><strong>Total Items:</strong> <%= order.totalQuantity %></p>
      <p><strong>Total Amount:</strong> <span style="font-size:20px; font-weight:700; color:#ffd700;">₹<%= order.totalAmount.toLocaleString('en-IN') %></span></p>

      <% if (order.userId) { %>
        <hr style="border-color:#334155; margin:15px 0;">
        <h4 style="margin-bottom:10px;">Customer</h4>
        <p><strong>Username:</strong> <%= order.userId.username %></p>
        <p><strong>Email:</strong> <%= order.userId.email %></p>
      <% } %>

      <% if (order.checkoutInfo) { %>
        <hr style="border-color:#334155; margin:15px 0;">
        <h4 style="margin-bottom:10px;">Delivery Info</h4>
        <p><strong>Name:</strong> <%= order.checkoutInfo.name %></p>
        <p><strong>Address:</strong> <%= order.checkoutInfo.address %></p>
        <p><strong>Phone:</strong> <%= order.checkoutInfo.phone %></p>
      <% } %>
    </div>

    <!-- Update Status -->
    <div style="margin-top:20px; padding-top:20px; border-top:1px solid #334155;">
      <h4 style="margin-bottom:12px;">Update Status</h4>
      <form action="/admin/orders/<%= order._id %>/status" method="POST" style="display:flex; gap:10px; flex-wrap:wrap;">
        <select name="status" style="flex:1; padding:10px; border:1px solid #334155; background:#0f172a; color:#f1f5f9; border-radius:6px; min-width:160px;">
          <% ['Pending','Processing','Shipped','Delivered','Cancelled'].forEach(s => { %>
            <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
        <button type="submit" class="admin-btn btn-primary">Update</button>
      </form>
    </div>

    <!-- Delete Order -->
    <div style="margin-top:15px;">
      <form action="/admin/orders/<%= order._id %>/delete" method="POST" onsubmit="return confirm('Permanently delete this order?')">
        <button type="submit" class="admin-btn btn-danger" style="width:100%;">
          <i class="fa-solid fa-trash"></i> Delete Order
        </button>
      </form>
    </div>
  </div>

  <!-- Order Items -->
  <div class="admin-card" style="flex:2; min-width:300px;">
    <div class="card-header">
      <h3>Order Items</h3>
    </div>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Product</th>
          <th>Price</th>
          <th>Qty</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% order.items.forEach(item => { %>
          <tr>
            <td>
              <img src="/uploads/<%= item.image %>" alt="<%= item.name %>"
                class="product-thumb" onerror="this.src='/img/placeholder.jpg'">
            </td>
            <td><%= item.name %></td>
            <td>₹<%= item.price.toLocaleString('en-IN') %></td>
            <td><%= item.quantity %></td>
            <td>₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div style="text-align:right; padding:15px; border-top:1px solid #334155;">
      <strong style="font-size:18px; color:#ffd700;">Total: ₹<%= order.totalAmount.toLocaleString('en-IN') %></strong>
    </div>
  </div>
</div>

<%- include('./partials/admin_footer') %>
