<%- include('./partials/admin_header', { activePage: 'products' }) %>

<div class="admin-header">
  <h2>Bulk Product Upload</h2>
  <a href="/admin/products" class="admin-btn btn-secondary btn-sm">← Back to Products</a>
</div>

<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error"><%= errors[0] %></div>
<% } %>
<% if (locals.success && success.length > 0) { %>
  <div class="alert alert-success"><%= success[0] %></div>
<% } %>

<div class="admin-card" style="max-width:800px; margin:0 auto;">
  <div class="card-header">
    <h3><i class="fa-solid fa-file-csv"></i> Import Products from CSV</h3>
  </div>

  <div class="info-box" style="background:#f8fafc; border-left:4px solid #088178; padding:15px; margin-bottom:20px; border-radius:4px;">
    <h4 style="margin-bottom:10px;"><i class="fa-solid fa-circle-info"></i> CSV Format Guidelines</h4>
    <p style="font-size:14px; color:#64748b;">To ensure a successful import, please make sure your CSV file follows this column structure:</p>
    <ul style="margin:10px 0 0 20px; font-size:13px; color:#475569;">
      <li><strong>name:</strong> Product Title (Required)</li>
      <li><strong>description:</strong> Detailed description</li>
      <li><strong>price:</strong> Numerical value (Required)</li>
      <li><strong>category:</strong> Electronics, Clothing, etc.</li>
      <li><strong>brand:</strong> Brand name</li>
      <li><strong>countInStock:</strong> Inventory count (Default: 0)</li>
      <li><strong>image:</strong> Primary image filename or URL</li>
    </ul>
    <div style="margin-top:15px;">
      <a href="#" id="download-sample" class="text-primary" style="font-weight:600; text-decoration:none;"><i class="fa-solid fa-download"></i> Download Sample Template</a>
    </div>
  </div>

  <form action="/admin/products/bulk" method="POST" enctype="multipart/form-data" class="admin-form">
    <div class="form-group">
      <label for="csv-file">Select CSV File <span class="required">*</span></label>
      <div style="border:2px dashed #e2e8f0; padding:40px; text-align:center; border-radius:8px; background:#fff; cursor:pointer;" onclick="document.getElementById('csv-file').click()">
        <i class="fa-solid fa-cloud-arrow-up" style="font-size:40px; color:#cbd5e1; margin-bottom:15px;"></i>
        <p id="file-name" style="color:#64748b;">Click to browse or drag and drop your CSV file here</p>
        <input type="file" id="csv-file" name="csvFile" accept=".csv" required style="display:none;" onchange="updateFileName(this)">
      </div>
    </div>

    <div style="margin-top:30px;">
      <button type="submit" class="admin-btn btn-primary" style="width:100%; padding:15px; font-size:16px;">
        <i class="fa-solid fa-upload"></i> Start Bulk Import
      </button>
    </div>
  </form>
</div>

<script>
  function updateFileName(input) {
    const fileName = input.files[0] ? input.files[0].name : "Click to browse or drag and drop your CSV file here";
    document.getElementById('file-name').textContent = fileName;
    document.getElementById('file-name').style.color = "#088178";
    document.getElementById('file-name').style.fontWeight = "bold";
  }

  // Generate and download a sample CSV
  document.getElementById('download-sample').addEventListener('click', function(e) {
    e.preventDefault();
    const csvContent = "name,description,price,category,brand,countInStock,image\n" +
                       "Summer T-Shirt,Premium cotton summer t-shirt,799,Clothing,EcomStyle,50,product1.jpg\n" +
                       "Leather Wallet,Handmade leather bifold wallet,1299,Accessories,Craftsman,20,wallet.jpg";
    
    const blob = new Blob([csvContent], { type: 'text/csv' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.setAttribute('href', url);
    a.setAttribute('download', 'ecomsphere_product_template.csv');
    a.click();
  });
</script>

<%- include('./partials/admin_footer') %>
