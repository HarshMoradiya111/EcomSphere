<%- include('./partials/admin_header', { activePage: 'coupons' }) %>

<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error"><%= errors[0] %></div>
<% } %>

<div class="admin-card" style="max-width:600px; margin:0 auto;">
  <div class="card-header">
    <h3><i class="fa-solid fa-pen-to-square"></i> Edit Coupon</h3>
    <a href="/admin/coupons" class="admin-btn btn-secondary btn-sm">← Back</a>
  </div>

  <form action="/admin/coupons/edit/<%= coupon._id %>" method="POST" class="admin-form">
    <div class="form-group">
      <label for="coupon-code">Coupon Code <span class="required">*</span></label>
      <input type="text" id="coupon-code" name="code" value="<%= coupon.code %>" required style="text-transform: uppercase;">
    </div>

    <div class="form-row" style="display:flex; gap:15px;">
      <div class="form-group" style="flex:1;">
        <label for="discount-type">Discount Type <span class="required">*</span></label>
        <select id="discount-type" name="discountType" required>
          <option value="percentage" <%= coupon.discountType === 'percentage' ? 'selected' : '' %>>Percentage (%)</option>
          <option value="flat" <%= coupon.discountType === 'flat' ? 'selected' : '' %>>Flat Amount (₹)</option>
        </select>
      </div>
      <div class="form-group" style="flex:1;">
        <label for="discount-value">Discount Value <span class="required">*</span></label>
        <input type="number" id="discount-value" name="discountValue" value="<%= coupon.discountValue %>" min="0" required>
      </div>
    </div>

    <div class="form-group">
      <label for="min-purchase">Minimum Purchase (₹)</label>
      <input type="number" id="min-purchase" name="minPurchase" value="<%= coupon.minPurchase %>" min="0">
    </div>

    <div class="form-group">
      <label for="expiry-date">Expiry Date <span class="required">*</span></label>
      <input type="date" id="expiry-date" name="expiryDate" value="<%= new Date(coupon.expiryDate).toISOString().split('T')[0] %>" required>
    </div>

    <div class="form-group">
      <label for="usage-limit">Usage Limit (optional)</label>
      <input type="number" id="usage-limit" name="usageLimit" value="<%= coupon.usageLimit %>" placeholder="e.g. 100" min="1">
      <small style="color:#94a3b8; font-size:12px;">Leave empty for unlimited use.</small>
    </div>

    <div class="form-group checkbox-group">
      <label style="display:flex; align-items:center; cursor:pointer;">
        <input type="checkbox" name="isActive" <%= coupon.isActive ? 'checked' : '' %> style="width:auto; margin-right:8px;">
        Coupon is Active
      </label>
    </div>

    <div style="margin-top:20px; display:flex; gap:12px;">
      <button type="submit" class="admin-btn btn-primary" style="flex:1;">
        <i class="fa-solid fa-floppy-disk"></i> Update Coupon
      </button>
      <a href="/admin/coupons" class="admin-btn btn-secondary" style="flex:1; text-align:center;">
        Cancel
      </a>
    </div>
  </form>
</div>

<%- include('./partials/admin_footer') %>
