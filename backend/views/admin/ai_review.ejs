<%- include('./partials/admin_header', { activePage: 'products' }) %>

<style>
  .review-container {
    max-width: 1200px;
    margin: 20px auto;
  }

  .review-card {
    background: white;
    border-radius: 15px;
    padding: 25px;
    margin-bottom: 25px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    border: 1px solid #eef2f6;
    display: flex;
    gap: 25px;
    animation: fadeIn 0.5s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .product-image-preview {
    width: 200px;
    height: 200px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid #e2e8f0;
  }

  .product-image-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-details-form {
    flex-grow: 1;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

  .form-full-width {
    grid-column: span 2;
  }

  .review-input {
    width: 100%;
    padding: 10px 15px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 14px;
    transition: border-color 0.2s;
  }

  .review-input:focus {
    border-color: #088178;
    outline: none;
    box-shadow: 0 0 0 3px rgba(8, 129, 120, 0.1);
  }

  .review-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: #64748b;
    margin-bottom: 5px;
    text-transform: uppercase;
  }

  .stats-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f8fafc;
    padding: 15px 25px;
    border-radius: 50px;
    margin-bottom: 30px;
  }

  .floating-save-bar {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    padding: 15px 40px;
    border-radius: 50px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    z-index: 100;
    display: flex;
    gap: 20px;
    align-items: center;
    border: 1px solid rgba(8, 129, 120, 0.2);
  }
</style>

<div class="review-container">
  <div class="admin-header">
    <div>
      <span style="color: #088178; font-weight: bold; text-transform: uppercase; font-size: 12px; letter-spacing: 1px;">Step 2: Review & Confirm</span>
      <h2>Fine-tune your AI Catalog</h2>
    </div>
    <a href="/admin/products/ai" class="admin-btn btn-secondary btn-sm">Discard & Restart</a>
  </div>

  <div class="stats-bar">
    <div>
      <strong style="color: #088178;"><%= products.length %></strong> Products identified by AI
    </div>
    <div style="font-size: 14px; color: #64748b;">
      <i class="fa-solid fa-circle-info"></i> You can edit any field before saving to the database.
    </div>
  </div>

  <% if (locals.errors && errors.length > 0) { %>
    <div class="alert alert-warning" style="margin-bottom: 25px;">
      <strong>Note:</strong> Some images had issues: <%= errors[0] %>
    </div>
  <% } %>

  <form action="/admin/products/save-ai" method="POST" id="final-save-form">
    <% products.forEach((product, index) => { %>
      <div class="review-card" style="animation-delay: <%= index * 0.1 %>s;">
        <div class="product-image-preview">
          <img src="/uploads/<%= product.tempImage %>" alt="Product">
          <input type="hidden" name="products[<%= index %>][image]" value="<%= product.tempImage %>">
        </div>

        <div class="product-details-form">
          <div class="form-full-width">
            <label class="review-label">Product Name</label>
            <input type="text" name="products[<%= index %>][name]" class="review-input" value="<%= product.name %>" required>
          </div>

          <div>
            <label class="review-label">Category</label>
            <select name="products[<%= index %>][category]" class="review-input" required>
              <% categories.forEach(cat => { %>
                <option value="<%= cat %>" <%= product.category === cat ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="review-label">Price (INR)</label>
            <input type="number" name="products[<%= index %>][price]" class="review-input" value="<%= product.price %>" step="0.01" required>
          </div>

          <div class="form-full-width">
            <label class="review-label">Marketing Description</label>
            <textarea name="products[<%= index %>][description]" class="review-input" rows="3" required><%= product.description %></textarea>
          </div>

          <div>
            <label class="review-label">Brand</label>
            <input type="text" name="products[<%= index %>][brand]" class="review-input" value="<%= product.brand || 'EcomSphere' %>">
          </div>

          <div>
            <label class="review-label">Initial Stock</label>
            <input type="number" name="products[<%= index %>][countInStock]" class="review-input" value="<%= product.countInStock || 20 %>" required>
          </div>
        </div>
      </div>
    <% }) %>

    <div style="height: 100px;"></div> <!-- Spacer for floating bar -->

    <div class="floating-save-bar">
      <div style="font-size: 14px;"><strong>Ready to launch?</strong> All details look correct.</div>
      <button type="submit" class="admin-btn btn-primary" style="padding: 10px 30px; border-radius: 30px;">
        <i class="fa-solid fa-cloud-arrow-up"></i> Save <%= products.length %> Products
      </button>
    </div>
  </form>
</div>

<%- include('./partials/admin_footer') %>
