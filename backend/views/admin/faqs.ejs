<%- include('./partials/admin_header', { activePage: 'faqs' }) %>

<!-- Flash messages -->
<% if (locals.success && success.length > 0) { %>
  <div class="alert alert-success">
    <% success.forEach(msg => { %><p><i class="fa-solid fa-circle-check"></i> <%= msg %></p><% }) %>
  </div>
<% } %>
<% if (locals.errors && errors.length > 0) { %>
  <div class="alert alert-error">
    <% errors.forEach(msg => { %><p><i class="fa-solid fa-circle-exclamation"></i> <%= msg %></p><% }) %>
  </div>
<% } %>

<div class="admin-card">
  <div class="card-header">
    <h3>Add New FAQ</h3>
  </div>
  <div style="padding:20px;">
    <form action="/admin/faqs/add" method="POST" class="admin-form">
      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
        <div class="form-group">
          <label>Category</label>
          <select name="category" class="form-control">
            <option value="General">General</option>
            <option value="Shipping">Shipping</option>
            <option value="Payments">Payments</option>
            <option value="Returns">Returns</option>
            <option value="Orders">Orders</option>
          </select>
        </div>
        <div class="form-group">
          <label>Order (Sort preference)</label>
          <input type="number" name="order" value="0" class="form-control">
        </div>
      </div>
      <div class="form-group">
        <label>Question</label>
        <input type="text" name="question" placeholder="Enter question" required class="form-control">
      </div>
      <div class="form-group">
        <label>Answer</label>
        <textarea name="answer" rows="4" placeholder="Enter answer" required class="form-control"></textarea>
      </div>
      <button type="submit" class="admin-btn btn-primary"><i class="fa-solid fa-plus"></i> Add FAQ</button>
    </form>
  </div>
</div>

<div class="admin-card" style="margin-top:30px;">
  <div class="card-header">
    <h3>Existing FAQs</h3>
  </div>
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Category</th>
          <th>Question</th>
          <th>Answer Snippet</th>
          <th>Order</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (faqs && faqs.length > 0) { %>
          <% faqs.forEach(faq => { %>
            <tr>
              <td><span class="badge badge-category"><%= faq.category %></span></td>
              <td><strong><%= faq.question %></strong></td>
              <td><%= faq.answer.substring(0, 50) %>...</td>
              <td><%= faq.order %></td>
              <td>
                <div style="display:flex; gap:5px;">
                  <a href="/admin/faqs/edit/<%= faq._id %>" class="admin-btn btn-primary btn-sm">Edit</a>
                  <form action="/admin/faqs/delete/<%= faq._id %>" method="POST" onsubmit="return confirm('Delete this FAQ?')">
                    <button type="submit" class="admin-btn btn-danger btn-sm">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="5" style="text-align:center; padding:30px; color:#999;">No FAQs added yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('./partials/admin_footer') %>
