<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <style>
    .compare-container { max-width: 1200px; margin: 40px auto; padding: 0 20px; overflow-x: auto; }
    .compare-table { width: 100%; border-collapse: collapse; min-width: 700px; border: 1px solid #eee; background: #fff; }
    .compare-table th, .compare-table td { padding: 25px 20px; text-align: center; border: 1px solid #eee; }
    .compare-table th { background: #f9f9f9; width: 200px; text-align: left; font-weight: 700; color: #1a1a1a; font-size: 16px; }
    .compare-img { width: 150px; height: 180px; object-fit: cover; border-radius: 8px; margin-bottom: 10px; }
    .compare-price { font-size: 20px; font-weight: 700; color: #088178; }
    .remove-compare { color: #ef4444; cursor: pointer; font-size: 14px; margin-top: 10px; display: inline-block; }
    .remove-compare:hover { text-decoration: underline; }
    
    .empty-compare { text-align: center; padding: 100px 20px; }
    .empty-compare i { font-size: 60px; color: #eee; margin-bottom: 20px; }
    .empty-compare h2 { color: #555; }
    
    .attr-label { color: #888; font-size: 12px; text-transform: uppercase; margin-bottom: 5px; display: block; }
  </style>
</head>
<body>

<%- include('./partials/header', { activePage: '' }) %>

<section id="page-header" class="about-header" style="background-image: url('/img/about/banner.png');">
  <h2>#CompareProducts</h2>
  <p>Compare features and choose the best for you</p>
</section>

<div class="compare-container">
  <% if (products && products.length > 0) { %>
    <table class="compare-table">
      <thead>
        <tr>
          <th>Products</th>
          <% products.forEach(product => { %>
            <td>
              <img src="/uploads/<%= product.image || 'default.jpg' %>" alt="<%= product.name %>" class="compare-img">
              <h4 style="margin: 10px 0;"><%= product.name %></h4>
              <p class="compare-price">₹<%= product.price.toLocaleString('en-IN') %></p>
              <a href="javascript:void(0)" onclick="removeFromCompare('<%= product._id %>')" class="remove-compare"><i class="fa-solid fa-trash-can"></i> Remove</a>
            </td>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th>Category</th>
          <% products.forEach(product => { %>
            <td><%= product.category %></td>
          <% }) %>
        </tr>
        <tr>
          <th>Description</th>
          <% products.forEach(product => { %>
            <td style="font-size: 14px; color: #666; max-width: 300px; line-height: 1.6;"><%= product.description.substring(0, 100) %>...</td>
          <% }) %>
        </tr>
        <tr>
          <th>Availability</th>
          <% products.forEach(product => { %>
            <td style="font-weight: 600; color: <%= product.countInStock > 0 ? '#22c55e' : '#ef4444' %>">
              <%= product.countInStock > 0 ? 'In Stock (' + product.countInStock + ')' : 'Out of Stock' %>
            </td>
          <% }) %>
        </tr>
        <tr>
          <th>Rating</th>
          <% products.forEach(product => { %>
            <td>
              <div style="color: #ffbd27;">
                <% const rating = Math.round(product.averageRating || 0); %>
                <% for(let i=1; i<=5; i++) { %>
                  <i class="fa-<%= i <= rating ? 'solid' : 'regular' %> fa-star"></i>
                <% } %>
                <div style="color: #888; font-size: 12px; margin-top: 5px;">(<%= product.numReviews %> reviews)</div>
              </div>
            </td>
          <% }) %>
        </tr>
        <tr>
          <th>Action</th>
          <% products.forEach(product => { %>
            <td>
              <a href="/product/<%= product._id %>" class="normal" style="padding: 10px 20px; font-size: 13px;">View Details</a>
            </td>
          <% }) %>
        </tr>
      </tbody>
    </table>
  <% } else { %>
    <div class="empty-compare">
      <i class="fa-solid fa-scale-unbalanced-flip"></i>
      <h2>No products selected for comparison</h2>
      <p>Go to our <a href="/shop" style="color: #088178; font-weight: 600;">Shop</a> and add some products to compare!</p>
    </div>
  <% } %>
</div>

<%- include('./partials/footer') %>

<script>
  window.removeFromCompare = function removeFromCompare(productId) {
    let compareList = JSON.parse(localStorage.getItem('compareItems') || '[]');
    compareList = compareList.filter(id => id !== productId);
    localStorage.setItem('compareItems', JSON.stringify(compareList));
    
    // Refresh with new list
    if (compareList.length > 0) {
      window.location.href = `/compare?ids=${compareList.join(',')}`;
    } else {
      window.location.href = '/compare';
    }
  };
</script>

<script src="/js/script.js"></script>
</body>
</html>
