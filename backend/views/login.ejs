<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Login to EcomSphere - Your premium online shopping destination">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
</head>
<body>
  <div class="wrapper">
    <span class="rotate-bg"></span>
    <span class="rotate-bg2"></span>

    <div class="form-box login">
      <h2 class="title animation" style="--i:0; --j:0">Login</h2>

      <%- include('./partials/flash') %>

      <form action="/auth/login" method="POST">
        <div class="input-box animation" style="--i:1; --j:1">
          <input type="email" name="email" id="login-email" required autocomplete="email">
          <label for="login-email">Email</label>
          <i class='bx bxs-envelope'></i>
        </div>

        <div class="input-box animation" style="--i:2; --j:2">
          <input type="password" name="password" id="login-password" required autocomplete="current-password">
          <label for="login-password">Password</label>
          <i class='bx bxs-lock-alt'></i>
        </div>

        <div class="forgot-link animation" style="--i:3; --j:3">
          <a href="/auth/forgot-password">Forgot Password?</a>
        </div>

        <button type="submit" class="btn animation" style="--i:4; --j:4">Login</button>
 
         <div class="social-login animation" style="--i:5; --j:5; margin-top: 15px; text-align: center;">
           <p style="margin-bottom: 10px; font-size: 14px; color: #fff;">Or sign in with</p>
           <a href="/auth/google" class="btn google-btn" style="background: #fff; color: #444; display: flex; align-items: center; justify-content: center; gap: 10px; text-decoration: none; font-weight: 600; border-radius: 6px; height: 45px; transition: 0.3s; width: 100%;">
             <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" width="18">
             Google
           </a>
         </div>
 
         <div class="linkTxt animation" style="--i:6; --j:6">
           <p>Don't have an account? <a href="/auth/register" class="register-link">Sign Up</a></p>
         </div>
       </form>
    </div>

    <div class="info-text login">
      <h2 class="animation" style="--i:0; --j:0">Welcome Back!</h2>
      <p class="animation" style="--i:1; --j:1">Shop the latest trends with EcomSphere. Sign in to access your cart, orders, and profile.</p>
    </div>

    <div class="form-box register">
      <h2 class="title animation" style="--i:17; --j:0">Sign Up</h2>
      <form action="/auth/register" method="POST">
        <div class="input-box animation" style="--i:18; --j:1">
          <input type="text" name="username" id="reg-username" required autocomplete="username">
          <label for="reg-username">Username</label>
          <i class='bx bxs-user'></i>
        </div>

        <div class="input-box animation" style="--i:19; --j:2">
          <input type="email" name="email" id="reg-email" required autocomplete="email">
          <label for="reg-email">Email</label>
          <i class='bx bxs-envelope'></i>
        </div>

        <div class="input-box animation" style="--i:20; --j:3">
          <input type="password" name="password" id="reg-password" required autocomplete="new-password">
          <label for="reg-password">Password</label>
          <i class='bx bxs-lock-alt'></i>
        </div>

        <div class="input-box animation" style="--i:20; --j:4">
          <input type="password" name="confirmPassword" id="reg-confirm-password" required autocomplete="new-password">
          <label for="reg-confirm-password">Confirm Password</label>
          <i class='bx bxs-lock-alt'></i>
        </div>

        <button type="submit" class="btn animation" style="--i:21; --j:5">Sign Up</button>
 
         <div class="social-login animation" style="--i:22; --j:6; margin-top: 15px; text-align: center;">
           <p style="margin-bottom: 10px; font-size: 14px; color: #fff;">Or sign up with</p>
           <a href="/auth/google" class="btn google-btn" style="background: #fff; color: #444; display: flex; align-items: center; justify-content: center; gap: 10px; text-decoration: none; font-weight: 600; border-radius: 6px; height: 45px; transition: 0.3s; width: 100%;">
             <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" width="18">
             Google
           </a>
         </div>
 
         <div class="linkTxt animation" style="--i:23; --j:7">
           <p>Already have an account? <a href="#" class="login-link">Login</a></p>
         </div>
       </form>
    </div>

    <div class="info-text register">
      <h2 class="animation" style="--i:17; --j:0">Join EcomSphere!</h2>
      <p class="animation" style="--i:18; --j:1">Create your account and start shopping from our premium collection of clothing, footwear, and more.</p>
    </div>
  </div>

  <script src="/js/auth.js"></script>
</body>
</html>
