<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Track your EcomSphere Order">
  <title><%= title %></title>
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .track-container { max-width: 800px; margin: 60px auto; padding: 40px; background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
    .track-container h2 { text-align: center; margin-bottom: 20px; font-size: 32px; color: #222; }
    
    .track-form { display: flex; gap: 10px; margin-bottom: 40px; justify-content: center; flex-wrap: wrap; }
    .track-form input { padding: 12px 20px; width: 60%; min-width: 250px; font-size: 15px; border: 1px solid #ccc; border-radius: 6px; outline: none; transition: 0.3s; }
    .track-form input:focus { border-color: #088178; box-shadow: 0 0 5px rgba(8, 129, 120, 0.2); }
    .track-form button { padding: 12px 30px; font-size: 15px; font-weight: 600; border-radius: 6px; background: #088178; color: #fff; border: none; cursor: pointer; transition: 0.3s; }
    .track-form button:hover { background: #066b64; }

    .track-result { border-top: 1px solid #eee; padding-top: 30px; }
    
    /* Progress Bar */
    .timeline { display: flex; justify-content: space-between; position: relative; margin: 50px 0 30px; }
    .timeline::before { content: ""; position: absolute; top: 18px; left: 0; width: 100%; height: 4px; background: #e0e0e0; z-index: 1; }
    .timeline-progress { position: absolute; top: 18px; left: 0; height: 4px; background: #088178; z-index: 2; transition: 0.5s ease; }
    
    .timeline-step { position: relative; z-index: 3; text-align: center; width: 25%; }
    .timeline-step .icon { width: 40px; height: 40px; border-radius: 50%; background: #e0e0e0; color: #fff; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; font-size: 16px; border: 3px solid #fff; transition: 0.3s; }
    .timeline-step.active .icon { background: #088178; }
    .timeline-step.completed .icon { background: #088178; }
    .timeline-step div { font-size: 13px; font-weight: 600; color: #888; }
    .timeline-step.completed div, .timeline-step.active div { color: #222; }

    /* Details */
    .track-details { background: #f9f9f9; padding: 20px; border-radius: 8px; margin-top: 20px; }
    .track-details h4 { font-size: 18px; margin-bottom: 12px; color: #333; }
    .track-details p { margin: 8px 0; font-size: 14px; color: #555; }
    
    .status-cancelled-box { text-align: center; color: #dc3545; padding: 30px; border: 2px dashed #dc3545; border-radius: 8px; margin: 20px 0; font-weight: 600; font-size: 20px; }
    .error-msg { background: #f8d7da; color: #721c24; padding: 12px 20px; border-radius: 6px; text-align: center; margin-bottom: 20px; border: 1px solid #f5c6cb; font-size: 14px; }
  </style>
</head>
<body>

  <%- include('./partials/header', { activePage: 'track' }) %>
  <%- include('./partials/breadcrumbs') %>

  <section class="section-p1">
    <div class="track-container">
      <h2>Track Your Order</h2>
      <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
        <div class="error-msg"><i class="fa-solid fa-triangle-exclamation"></i> <%= errorMsg %></div>
      <% } %>

      <% if (typeof order !== 'undefined' && order) { %>
        <p style="text-align: center; color: #666; margin-bottom: 25px;">Checking the real-time status of your shipment.</p>
        <div class="track-result">
          <h3 style="text-align:center; font-size:22px; color:#088178;">Order #<%= order._id.toString().slice(-8).toUpperCase() %></h3>
          
          <% if (order.status === 'Cancelled') { %>
            <div class="status-cancelled-box">
              <i class="fa-solid fa-ban" style="font-size: 40px; display:block; margin-bottom:10px;"></i>
              This order has been Cancelled.
            </div>
          <% } else { %>
            <% 
              const statuses = ['Pending', 'Processing', 'Shipped', 'Delivered'];
              const currentIndex = statuses.indexOf(order.status);
              const progressPercentage = currentIndex === 0 ? 12 : (currentIndex === 1 ? 38 : (currentIndex === 2 ? 63 : 100));
            %>
            <div class="timeline" id="tracking-timeline">
              <div class="timeline-progress" id="timeline-bar" data-progress="<%= progressPercentage %>"></div>
              <script>
                document.addEventListener('DOMContentLoaded', () => {
                  const bar = document.getElementById('timeline-bar');
                  if (bar) bar.style.width = bar.getAttribute('data-progress') + '%';
                });
              </script>
              
              <div class="timeline-step <%= currentIndex >= 0 ? 'completed' : '' %>">
                <div class="icon"><i class="fa-solid fa-box"></i></div>
                <div>Pending</div>
              </div>
              <div class="timeline-step <%= currentIndex >= 1 ? 'completed' : '' %>">
                <div class="icon"><i class="fa-solid fa-spinner"></i></div>
                <div>Processing</div>
              </div>
              <div class="timeline-step <%= currentIndex >= 2 ? 'completed' : '' %>">
                <div class="icon"><i class="fa-solid fa-truck-fast"></i></div>
                <div>Shipped</div>
              </div>
              <div class="timeline-step <%= currentIndex >= 3 ? 'completed' : '' %>">
                <div class="icon"><i class="fa-solid fa-house-circle-check"></i></div>
                <div>Delivered</div>
              </div>
            </div>
          <% } %>

          <div class="track-details">
            <h4><i class="fa-solid fa-file-invoice"></i> Order Details</h4>
            <p><strong>Date Placed:</strong> <%= new Date(order.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
            <p><strong>Total Items:</strong> <%= order.totalQuantity %></p>
            <p><strong>Total Amount:</strong> ₹<%= order.totalAmount.toLocaleString('en-IN') %></p>
            <p><strong>Deliver To:</strong> <%= order.checkoutInfo.name %> (<%= order.checkoutInfo.address %>)</p>
          </div>
        </div>
      <% } else if (!(typeof errorMsg !== 'undefined' && errorMsg)) { %>
        <div style="text-align:center; padding:40px; background:#f9f9f9; border-radius:10px;">
          <i class="fa-solid fa-truck-fast" style="font-size:50px; color:#ccc;"></i>
          <p style="color:#666; margin-top:15px; font-size:18px;">Please select an order from your profile to track it.</p>
          <a href="/profile" style="display:inline-block; margin-top:15px; padding:10px 20px; background:#088178; color:#fff; border-radius:6px; text-decoration:none;">Go to My Orders</a>
        </div>
      <% } %>

    </div>
  </section>

  <%- include('./partials/footer') %>

  <script src="/js/script.js"></script>
</body>
</html>
