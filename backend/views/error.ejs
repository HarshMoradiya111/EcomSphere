<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Oops! Something went wrong | EcomSphere</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://kit.fontawesome.com/db75cd62a8.js" crossorigin="anonymous"></script>
  <style>
    .error-container { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 20px; background: #fff; }
    .error-icon { font-size: 100px; color: #ffab00; margin-bottom: 20px; animation: pulse 2s infinite; }
    @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
    .error-title { font-size: 32px; font-weight: 900; color: #1a1a1a; margin-bottom: 10px; }
    .error-text { font-size: 16px; color: #666; max-width: 500px; line-height: 1.6; margin-bottom: 40px; }
    .error-details { background: #f8f9fa; padding: 20px; border-radius: 10px; border: 1px solid #eee; margin-bottom: 40px; max-width: 600px; width: 100%; text-align: left; }
    .error-details summary { cursor: pointer; color: #088178; font-weight: 700; outline: none; }
    .error-details pre { margin-top: 15px; font-size: 12px; color: #d32f2f; white-space: pre-wrap; word-wrap: break-word; overflow: auto; max-height: 200px; }
    .btn-premium { background: #088178; color: #fff; padding: 15px 40px; border-radius: 40px; font-weight: bold; font-size: 15px; text-decoration: none; box-shadow: 0 10px 20px rgba(8, 129, 120, 0.2); transition: 0.3s; }
    .btn-premium:hover { background: #066b64; transform: translateY(-3px); }
  </style>
</head>
<body>
  <%- include('./partials/header') %>
  <%- include('./partials/flash') %>

  <div class="error-container">
    <div class="error-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
    <h1 class="error-title">Something went wrong!</h1>
    <p class="error-text">Our tech team has been notified. We are working hard to fix this as quickly as possible. Don't worry, your cart is safe!</p>
    
    <% if (typeof error !== 'undefined' && process.env.NODE_ENV === 'development') { %>
        <details class="error-details">
            <summary>View Technical Details (Debug Only)</summary>
            <pre><%= error.stack %></pre>
        </details>
    <% } %>

    <div class="error-actions">
        <a href="/" class="btn-premium"><i class="fa-solid fa-house"></i> Return to Homepage</a>
    </div>
  </div>

  <%- include('./partials/footer') %>
</body>
</html>
